<%- include("partials/head", { pageTitle, bodyClass: "auth-body auth-body--vote" }) %>

<%
  const opensAtMs = settings.opensAt ? Date.parse(settings.opensAt) : Number.NaN;
  const closesAtMs = settings.closesAt ? Date.parse(settings.closesAt) : Number.NaN;
  const loginCountdownTarget = electionState.isScheduled
    ? opensAtMs
    : electionState.isOpen
      ? closesAtMs
      : Number.NaN;
  const hasLoginCountdown = Number.isFinite(loginCountdownTarget) && loginCountdownTarget > 0;
  const loginCountdownTitle = electionState.isScheduled ? "Election opens in" : "Election ends in";
  const loginCountdownEndedLabel = electionState.isScheduled ? "Voting is now open" : "Voting has closed";
  const authStatusClass = electionState.isOpen
    ? "is-open"
    : electionState.isScheduled
      ? "is-scheduled"
      : electionState.isClosed
        ? "is-closed"
        : "is-setup";
  const authStatusLabel = electionState.isOpen
    ? "OPEN"
    : electionState.isScheduled
      ? "SCHEDULED"
      : electionState.isClosed
        ? "CLOSED"
        : "SETUP";
  const authStatusCopy = electionState.isOpen
    ? "Live voting in progress"
    : electionState.isScheduled
      ? "Voting opens soon"
      : electionState.isClosed
        ? "Voting window closed"
        : "Election setup in progress";
  const loginButtonLabel = otpEnabled ? "Request Code" : "Login";
  const loginLoadingLabel = otpEnabled ? "Requesting code..." : "Signing in...";
  const loginIntroCopy = otpEnabled
    ? "Enter your details to receive a one-time verification code."
    : "Enter your verified voter details to continue to the ballot.";
  const loginConfidentialityCopy = otpEnabled
    ? "Your information is encrypted and kept confidential."
    : "Your voter information is matched securely before the ballot opens.";
  const electionDateValue = (() => {
    const source = settings.closesAt || settings.opensAt;
    if (!source) {
      return "To be announced";
    }
    const parsed = new Date(source);
    if (Number.isNaN(parsed.getTime())) {
      return "To be announced";
    }
    return parsed.toLocaleDateString("en-US", {
      month: "short",
      day: "2-digit",
      year: "numeric",
      timeZone: "UTC",
    });
  })();
%>

<div class="auth-page auth-page--vote">
  <section class="auth-desktop-shell">
    <header class="auth-desktop-header">
      <a class="auth-brand" href="/">
        <% if (settings.organizationLogoPath) { %>
          <img class="auth-brand__logo" src="<%= settings.organizationLogoPath %>" alt="<%= settings.electionName %> logo" />
        <% } else { %>
          <span class="auth-brand__crest">VP</span>
        <% } %>
        <span class="auth-brand__copy">
          <strong><%= settings.electionName %></strong>
          <small>Election Portal</small>
        </span>
      </a>

      <div class="auth-desktop-header__status">
        <span class="auth-state-pill <%= authStatusClass %>">
          <span class="auth-state-pill__dot"></span>
          <%= authStatusLabel %>
        </span>
        <span class="auth-desktop-header__divider" aria-hidden="true"></span>
        <p><%= authStatusCopy %></p>
        <span class="auth-desktop-header__divider" aria-hidden="true"></span>
        <p>Secure. Fair. Transparent.</p>
      </div>
    </header>

    <main class="auth-desktop-main">
      <%- include("partials/flash") %>

      <section class="auth-stage auth-stage--vote">
        <div class="auth-stage__dotfield" aria-hidden="true"></div>
        <div class="auth-stage__building" aria-hidden="true"></div>
        <div class="auth-stage__arc" aria-hidden="true"></div>
        <div class="auth-stage__glow auth-stage__glow--green" aria-hidden="true"></div>

        <div class="auth-stage__grid">
          <article class="auth-hero-copy">
            <span class="auth-hero-copy__badge" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M12 2 4 5.5v5.22c0 5.18 3.42 9.99 8 11.28 4.58-1.29 8-6.1 8-11.28V5.5L12 2Zm-1.07 13.82L7.76 12.65l1.41-1.41 1.76 1.76 4.24-4.24 1.41 1.41-5.65 5.65Z" fill="currentColor"/>
              </svg>
            </span>

            <h1>
              Secure <span>ballot</span><br />
              access
            </h1>

            <p>
              Sign in with your staff ID and registered phone number to access the election
              ballot securely.
            </p>

            <div class="auth-schedule-card">
              <span class="auth-schedule-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M7 2h2v2h6V2h2v2h2a2 2 0 0 1 2 2v12a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6a2 2 0 0 1 2-2h2V2Zm12 8H5v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-8Z" fill="currentColor"/>
                </svg>
              </span>
              <div class="auth-schedule-card__copy">
                <span>Voting Opens</span>
                <strong><%= settings.opensAt ? formatDateTime(settings.opensAt) : "Not scheduled yet" %></strong>
              </div>
            </div>

            <div class="auth-schedule-card">
              <span class="auth-schedule-card__icon auth-schedule-card__icon--lock" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M17 8h-1V6a4 4 0 1 0-8 0v2H7a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2Zm-6 0V6a2 2 0 1 1 4 0v2h-4Z" fill="currentColor"/>
                </svg>
              </span>
              <div class="auth-schedule-card__copy">
                <span>Voting Closes</span>
                <strong><%= settings.closesAt ? formatDateTime(settings.closesAt) : "Not scheduled yet" %></strong>
              </div>
            </div>
          </article>

          <article class="auth-login-panel">
            <span class="auth-login-panel__icon" aria-hidden="true">
              <svg viewBox="0 0 64 64" focusable="false">
                <circle cx="32" cy="32" r="32" fill="currentColor" opacity=".08" />
                <path d="M32 18a8 8 0 1 0 8 8 8 8 0 0 0-8-8Zm0 20c-7.18 0-13 3.58-13 8v2h26v-2c0-4.42-5.82-8-13-8Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.6"/>
                <path d="M46.5 23.5h-3v-1a4.5 4.5 0 1 0-9 0v1h-2.2a1.8 1.8 0 0 0-1.8 1.8v7.4a1.8 1.8 0 0 0 1.8 1.8h5.4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4"/>
                <path d="M46.5 36.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11Zm0 2.7v5.6m-2.8-2.8h5.6" fill="none" stroke="#15945e" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2"/>
              </svg>
            </span>

            <h2>Staff Verification</h2>
            <p><%= loginIntroCopy %></p>

            <form class="auth-form" action="/vote/login" method="post" data-auth-login-form>
              <label class="auth-field">
                <span>STAFF ID</span>
                <div class="auth-field__control">
                  <span class="auth-field__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                      <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-3.31 0-6 1.79-6 4v1h12v-1c0-2.21-2.69-4-6-4Z" fill="currentColor"/>
                    </svg>
                  </span>
                  <input
                    name="staffId"
                    placeholder="e.g. STF0234"
                    autocomplete="username"
                    required
                  />
                </div>
              </label>

              <label class="auth-field">
                <span>PHONE NUMBER</span>
                <div class="auth-field__control">
                  <span class="auth-field__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                      <path d="M7.05 4.5h2.1c.38 0 .71.26.8.63l.72 2.88a.84.84 0 0 1-.21.79l-1.37 1.37a13.53 13.53 0 0 0 4.74 4.74l1.37-1.37a.84.84 0 0 1 .79-.21l2.88.72c.37.09.63.42.63.8v2.1c0 .47-.38.85-.85.85A14.65 14.65 0 0 1 6.2 5.35c0-.47.38-.85.85-.85Z" fill="currentColor"/>
                    </svg>
                  </span>
                  <input
                    name="phoneNumber"
                    placeholder="e.g. 024 123 4567"
                    inputmode="tel"
                    autocomplete="tel"
                    required
                  />
                </div>
              </label>

              <%- include("partials/captcha-widget") %>

              <button class="auth-submit" type="submit" data-auth-login-submit data-loading-label="<%= loginLoadingLabel %>" <%= electionState.isOpen ? "" : "disabled" %>>
                <span class="auth-submit__spinner" aria-hidden="true"></span>
                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                  <path d="M12 2a4 4 0 0 0-4 4v3H7a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2h-1V6a4 4 0 0 0-4-4Zm-2 7V6a2 2 0 1 1 4 0v3h-4Z" fill="currentColor"/>
                </svg>
                <span class="auth-submit__label"><%= loginButtonLabel %></span>
              </button>
            </form>

            <div class="auth-login-panel__privacy">
              <span class="auth-login-panel__privacy-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M12 2 4 5.5v5.22c0 5.18 3.42 9.99 8 11.28 4.58-1.29 8-6.1 8-11.28V5.5L12 2Zm-1.07 13.82L7.76 12.65l1.41-1.41 1.76 1.76 4.24-4.24 1.41 1.41-5.65 5.65Z" fill="currentColor"/>
                </svg>
              </span>
              <p><%= loginConfidentialityCopy %></p>
            </div>

            <% if (!electionState.isOpen) { %>
              <p class="auth-inline-note"><%= electionState.message %></p>
            <% } %>
          </article>
        </div>
      </section>

      <section
        class="auth-countdown-strip"
        data-auth-countdown
        data-countdown-target="<%= hasLoginCountdown ? loginCountdownTarget : '' %>"
        data-countdown-ended-label="<%= loginCountdownEndedLabel %>"
      >
        <div class="auth-countdown-strip__label">
          <span class="auth-countdown-strip__label-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 3a9 9 0 1 0 9 9 9.01 9.01 0 0 0-9-9Zm1 9.59 3.3 3.3-1.41 1.41L11 13V7h2Z" fill="currentColor"/>
            </svg>
          </span>
          <div>
            <span class="auth-countdown-strip__eyebrow" data-countdown-title><%= hasLoginCountdown ? loginCountdownTitle : "Election countdown pending" %></span>
          </div>
        </div>

        <div class="auth-countdown-strip__timer" aria-live="polite" aria-atomic="true">
          <div class="auth-countdown-tile">
            <strong data-countdown-days><%= hasLoginCountdown ? "00" : "--" %></strong>
            <span>DAYS</span>
          </div>
          <span class="auth-countdown-separator" aria-hidden="true">:</span>
          <div class="auth-countdown-tile">
            <strong data-countdown-hours><%= hasLoginCountdown ? "00" : "--" %></strong>
            <span>HOURS</span>
          </div>
          <span class="auth-countdown-separator" aria-hidden="true">:</span>
          <div class="auth-countdown-tile">
            <strong data-countdown-minutes><%= hasLoginCountdown ? "00" : "--" %></strong>
            <span>MINUTES</span>
          </div>
          <span class="auth-countdown-separator" aria-hidden="true">:</span>
          <div class="auth-countdown-tile">
            <strong data-countdown-seconds><%= hasLoginCountdown ? "00" : "--" %></strong>
            <span>SECONDS</span>
          </div>
        </div>

        <div class="auth-countdown-strip__meta">
          <span class="auth-countdown-strip__label-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M7 2h2v2h6V2h2v2h2a2 2 0 0 1 2 2v12a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6a2 2 0 0 1 2-2h2V2Zm12 8H5v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-8Z" fill="currentColor"/>
            </svg>
          </span>
          <div>
            <span>Election Date</span>
            <strong><%= electionDateValue %></strong>
          </div>
        </div>
      </section>
    </main>
  </section>

  <section class="auth-mobile-shell">
    <div class="auth-mobile-shell__top-curve" aria-hidden="true"></div>
    <div class="auth-mobile-shell__bottom-curve" aria-hidden="true"></div>
    <div class="auth-mobile-shell__lineart" aria-hidden="true"></div>

    <main class="auth-mobile-main">
      <%- include("partials/flash") %>

      <a class="auth-mobile-brand" href="/">
        <% if (settings.organizationLogoPath) { %>
          <img src="<%= settings.organizationLogoPath %>" alt="<%= settings.electionName %> logo" />
        <% } else { %>
          <span class="auth-mobile-brand__crest">VP</span>
        <% } %>
        <span>
          <strong><%= settings.electionName %></strong>
          <small>Election Portal</small>
        </span>
      </a>

      <article class="auth-mobile-card">
        <span class="auth-mobile-card__icon auth-mobile-card__icon--vote" aria-hidden="true">
          <svg viewBox="0 0 160 160" focusable="false">
            <circle cx="80" cy="80" r="78" fill="currentColor" opacity=".08" />
            <circle cx="80" cy="80" r="60" fill="currentColor" opacity=".08" />
            <path d="M56 62h48l6 58H50l6-58Zm11-18h26l19 16H48l19-16Zm21 0-8 16M69 25l35 11-8 16-35-11Z" fill="#204dbf" opacity=".18"/>
            <path d="M55 63h50v56H55z" fill="#1f4db8"/>
            <path d="M50 60h60v12H50z" fill="#193e96"/>
            <path d="M72 80h16v22H72z" fill="none"/>
            <path d="M70 88h20" stroke="#fff" stroke-linecap="round" stroke-width="4"/>
            <path d="m91 38 12 13-14 13-12-13Z" fill="#fff"/>
            <path d="m85 50 6 6 12-12" fill="none" stroke="#2457e6" stroke-linecap="round" stroke-linejoin="round" stroke-width="4"/>
          </svg>
        </span>

        <h1>VOTERS LOGIN</h1>

        <div class="auth-mobile-card__divider" aria-hidden="true">
          <span></span>
          <i>
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="m12 3 2.8 5.67 6.27.91-4.53 4.41 1.07 6.24L12 17.26 6.39 20.23l1.07-6.24L2.93 9.58l6.27-.91L12 3Z" fill="currentColor"/>
            </svg>
          </i>
          <span></span>
        </div>

        <p class="auth-mobile-card__lead">
          Login to access your voter portal and manage your details.
        </p>

        <form class="auth-mobile-form" action="/vote/login" method="post" data-auth-login-form>
          <label class="auth-mobile-field">
            <span>Staff ID</span>
            <div class="auth-mobile-field__control">
              <span class="auth-mobile-field__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-3.31 0-6 1.79-6 4v1h12v-1c0-2.21-2.69-4-6-4Z" fill="currentColor"/>
                </svg>
              </span>
              <input
                name="staffId"
                placeholder="Enter your Staff ID"
                autocomplete="username"
                required
              />
            </div>
          </label>

          <label class="auth-mobile-field">
            <span>Phone Number</span>
            <div class="auth-mobile-field__control">
              <span class="auth-mobile-field__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M7.05 4.5h2.1c.38 0 .71.26.8.63l.72 2.88a.84.84 0 0 1-.21.79l-1.37 1.37a13.53 13.53 0 0 0 4.74 4.74l1.37-1.37a.84.84 0 0 1 .79-.21l2.88.72c.37.09.63.42.63.8v2.1c0 .47-.38.85-.85.85A14.65 14.65 0 0 1 6.2 5.35c0-.47.38-.85.85-.85Z" fill="currentColor"/>
                </svg>
              </span>
              <input
                name="phoneNumber"
                placeholder="Enter your Phone Number"
                inputmode="tel"
                autocomplete="tel"
                required
              />
            </div>
          </label>

          <%- include("partials/captcha-widget") %>

          <button class="auth-mobile-submit" type="submit" data-auth-login-submit data-loading-label="<%= loginLoadingLabel %>" <%= electionState.isOpen ? "" : "disabled" %>>
            <span class="auth-submit__spinner" aria-hidden="true"></span>
            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
              <path d="M10.2 6.4 8.8 7.8 12.99 12l-4.2 4.2 1.42 1.4 5.6-5.6-5.6-5.6Z" fill="currentColor"/>
            </svg>
            <span class="auth-submit__label"><%= loginButtonLabel %></span>
          </button>
        </form>

        <% if (!electionState.isOpen) { %>
          <p class="auth-inline-note auth-inline-note--mobile"><%= electionState.message %></p>
        <% } %>

        <div class="auth-mobile-card__or">
          <span></span>
          <strong>OR</strong>
          <span></span>
        </div>

        <a class="auth-mobile-card__support" href="tel:+233592934612">
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-3.31 0-6 1.79-6 4v1h12v-1c0-2.21-2.69-4-6-4Zm7-10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-3.17l-2.2 2.2a.8.8 0 0 1-1.13 0L10.3 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
            </svg>
          </span>
          <span>Need Help? Contact Support</span>
        </a>
      </article>

      <p class="auth-mobile-main__tagline">
        <span aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M12 2 4 5.5v5.22c0 5.18 3.42 9.99 8 11.28 4.58-1.29 8-6.1 8-11.28V5.5L12 2Zm-1.07 13.82L7.76 12.65l1.41-1.41 1.76 1.76 4.24-4.24 1.41 1.41-5.65 5.65Z" fill="currentColor"/>
          </svg>
        </span>
        <span>Your Vote. Your Voice. Your Future.</span>
      </p>
    </main>
  </section>
</div>

<script>
  (() => {
    document.querySelectorAll("[data-auth-login-form]").forEach((form) => {
      form.addEventListener("submit", () => {
        if (!form.checkValidity()) {
          return;
        }

        const submitButton = form.querySelector("[data-auth-login-submit]");
        if (!submitButton || submitButton.classList.contains("is-loading")) {
          return;
        }

        const buttonLabel = submitButton.querySelector(".auth-submit__label");
        submitButton.classList.add("is-loading");
        submitButton.setAttribute("aria-busy", "true");
        submitButton.disabled = true;
        if (buttonLabel) {
          buttonLabel.textContent = submitButton.getAttribute("data-loading-label") || "Please wait...";
        }
      });
    });
  })();

  (() => {
    const countdownRoot = document.querySelector("[data-auth-countdown]");
    if (!countdownRoot) {
      return;
    }

    const targetTime = Number(countdownRoot.getAttribute("data-countdown-target") || "0");
    if (!Number.isFinite(targetTime) || targetTime <= 0) {
      return;
    }

    const dayEl = countdownRoot.querySelector("[data-countdown-days]");
    const hourEl = countdownRoot.querySelector("[data-countdown-hours]");
    const minuteEl = countdownRoot.querySelector("[data-countdown-minutes]");
    const secondEl = countdownRoot.querySelector("[data-countdown-seconds]");
    const titleEl = countdownRoot.querySelector("[data-countdown-title]");
    const endedLabel = countdownRoot.getAttribute("data-countdown-ended-label") || "Voting has closed";

    const paint = (element, value) => {
      if (!element) {
        return;
      }
      element.textContent = String(value).padStart(2, "0");
    };

    let intervalId = null;

    const updateCountdown = () => {
      const remainingMs = Math.max(0, targetTime - Date.now());
      const totalSeconds = Math.floor(remainingMs / 1000);
      const days = Math.floor(totalSeconds / 86400);
      const hours = Math.floor((totalSeconds % 86400) / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;

      paint(dayEl, days);
      paint(hourEl, hours);
      paint(minuteEl, minutes);
      paint(secondEl, seconds);

      if (remainingMs <= 0) {
        if (titleEl) {
          titleEl.textContent = endedLabel;
        }
        if (intervalId) {
          window.clearInterval(intervalId);
        }
      }
    };

    updateCountdown();
    intervalId = window.setInterval(updateCountdown, 1000);
  })();
</script>
</body>
</html>
