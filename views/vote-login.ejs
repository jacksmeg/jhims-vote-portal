<%- include("partials/public-shell-start", { pageTitle }) %>

<%
  const opensAtMs = settings.opensAt ? Date.parse(settings.opensAt) : Number.NaN;
  const closesAtMs = settings.closesAt ? Date.parse(settings.closesAt) : Number.NaN;
  const loginCountdownTarget = electionState.isScheduled
    ? opensAtMs
    : electionState.isOpen
      ? closesAtMs
      : Number.NaN;
  const hasLoginCountdown = Number.isFinite(loginCountdownTarget) && loginCountdownTarget > 0;
  const loginCountdownTitle = electionState.isScheduled ? 'Voting opens in' : 'Voting closes in';
  const loginCountdownEndedLabel = electionState.isScheduled ? 'Voting is now open' : 'Voting has closed';
  const loginCountdownNote = electionState.isScheduled
    ? 'The portal will unlock automatically at the official opening time.'
    : 'Finish your ballot before the official closing time.';
%>

<section class="portal-login-stage">
  <article class="portal-showcase">
    <div class="portal-showcase__backdrop"></div>

    <div class="portal-showcase__hero">
      <div class="portal-copy">
        <h1>
          Your Vote.
          <span>Our Future.</span>
        </h1>

        <p>
          A secure, transparent and trusted voting experience for every eligible staff member.
        </p>

        <div class="portal-checklist">
          <div>
            <span class="portal-checklist__dot portal-checklist__dot--green"></span>
            <span>One person, one vote</span>
          </div>
          <div>
            <span class="portal-checklist__dot portal-checklist__dot--blue"></span>
            <span>Secure and confidential</span>
          </div>
          <div>
            <span class="portal-checklist__dot portal-checklist__dot--orange"></span>
            <span>Transparent results</span>
          </div>
        </div>
      </div>

      <article class="voter-auth-card">
        <div class="voter-auth-card__header">
          <div>
            <h2>Voter Login</h2>
            <p>Enter your voter details to continue.</p>
          </div>
        </div>

        <form class="stack-md" action="/vote/login" method="post">
          <label class="field field--icon">
            <span>Staff ID</span>
            <div class="field__control">
              <span class="field__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-3.31 0-6 1.79-6 4v1h12v-1c0-2.21-2.69-4-6-4Z" fill="currentColor"/>
                </svg>
              </span>
              <input name="staffId" placeholder="e.g. STF0234" required />
            </div>
          </label>

          <label class="field field--icon">
            <span>Phone Number</span>
            <div class="field__control">
              <span class="field__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M7.05 4.5h2.1c.38 0 .71.26.8.63l.72 2.88a.84.84 0 0 1-.21.79l-1.37 1.37a13.53 13.53 0 0 0 4.74 4.74l1.37-1.37a.84.84 0 0 1 .79-.21l2.88.72c.37.09.63.42.63.8v2.1c0 .47-.38.85-.85.85A14.65 14.65 0 0 1 6.2 5.35c0-.47.38-.85.85-.85Z" fill="currentColor"/>
                </svg>
              </span>
              <input name="phoneNumber" placeholder="e.g. 024 123 4567" required />
            </div>
          </label>

          <button class="button voter-auth-card__submit" type="submit" <%= electionState.isOpen ? '' : 'disabled' %>>
            <%= otpEnabled ? 'Send OTP Code' : 'Continue to Ballot' %>
          </button>
        </form>

        <p class="voter-auth-card__helper">
          <% if (otpEnabled) { %>
            We will send a verification code to your registered phone.
          <% } else { %>
            Your ballot opens immediately after successful verification.
          <% } %>
        </p>

        <% if (!electionState.isOpen) { %>
          <p class="note-block"><%= electionState.message %></p>
        <% } %>
      </article>
    </div>

    <div class="portal-meta-grid">
      <article
        class="portal-meta-card portal-meta-card--countdown"
        <% if (hasLoginCountdown) { %>
          data-countdown-root
          data-countdown-target="<%= loginCountdownTarget %>"
          data-countdown-ended-label="<%= loginCountdownEndedLabel %>"
        <% } %>
      >
        <div class="portal-meta-card__header">
          <span class="portal-meta-card__icon portal-meta-card__icon--amber" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M8 3h8v2l-1.5 1.5v2.17a5.5 5.5 0 1 1-5 0V6.5L8 5V3Zm4 8.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Z" fill="currentColor"/>
            </svg>
          </span>
          <div>
            <strong>Election Countdown</strong>
            <small data-countdown-copy><%= hasLoginCountdown ? loginCountdownNote : 'The election committee will publish the final timing here.' %></small>
          </div>
        </div>

        <div class="portal-countdown">
          <div class="portal-countdown__copy">
            <h3 data-countdown-title><%= hasLoginCountdown ? loginCountdownTitle : 'Countdown pending' %></h3>
          </div>

          <div class="portal-countdown__grid" aria-live="polite" aria-atomic="true">
            <div class="portal-countdown__unit">
              <strong data-countdown-days><%= hasLoginCountdown ? '00' : '--' %></strong>
              <span>Days</span>
            </div>
            <div class="portal-countdown__unit">
              <strong data-countdown-hours><%= hasLoginCountdown ? '00' : '--' %></strong>
              <span>Hours</span>
            </div>
            <div class="portal-countdown__unit">
              <strong data-countdown-minutes><%= hasLoginCountdown ? '00' : '--' %></strong>
              <span>Minutes</span>
            </div>
            <div class="portal-countdown__unit">
              <strong data-countdown-seconds><%= hasLoginCountdown ? '00' : '--' %></strong>
              <span>Seconds</span>
            </div>
          </div>
        </div>
      </article>

      <article class="portal-meta-card">
        <div class="portal-meta-card__header">
          <span class="portal-meta-card__icon portal-meta-card__icon--blue" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M7 2h2v2h6V2h2v2h2.5A1.5 1.5 0 0 1 21 5.5v13A1.5 1.5 0 0 1 19.5 20h-15A1.5 1.5 0 0 1 3 18.5v-13A1.5 1.5 0 0 1 4.5 4H7V2Zm12 7H5v9h14V9Z" fill="currentColor"/>
            </svg>
          </span>
          <div>
            <strong>Election Window</strong>
            <small>All times are in GMT</small>
          </div>
        </div>

        <dl class="portal-window-list">
          <div>
            <dt>Opens</dt>
            <dd><%= settings.opensAt ? formatDateTime(settings.opensAt) : 'Not scheduled yet' %></dd>
          </div>
          <div>
            <dt>Closes</dt>
            <dd><%= settings.closesAt ? formatDateTime(settings.closesAt) : 'Not scheduled yet' %></dd>
          </div>
        </dl>
      </article>
    </div>

    <aside class="portal-assurance">
      <span class="portal-assurance__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 2 4 5.5v5.22c0 5.18 3.42 9.99 8 11.28 4.58-1.29 8-6.1 8-11.28V5.5L12 2Zm-1.07 13.82L7.76 12.65l1.41-1.41 1.76 1.76 4.24-4.24 1.41 1.41-5.65 5.65Z" fill="currentColor"/>
        </svg>
      </span>
      <div>
        <strong>This election is managed by the Election Committee.</strong>
        <span>Your vote is protected and your choice is confidential.</span>
      </div>
    </aside>
  </article>
</section>

<section class="panel panel-light stack-lg walkthrough-panel" id="vote-demo">
  <div class="section-heading">
    <div>
      <span class="eyebrow">Animated Walkthrough</span>
      <h3>Watch exactly how staff vote in this portal.</h3>
    </div>
    <p class="muted-text">
      This in-app demo follows the same login, ballot, review, and submission flow voters use on the
      real system.
    </p>
  </div>

  <div class="walkthrough-shell" data-walkthrough data-walkthrough-interval="4400">
    <div class="walkthrough-stage">
      <% voteWalkthrough.steps.forEach((step, stepIndex) => { %>
        <article
          class="walkthrough-slide <%= stepIndex === 0 ? 'is-active' : '' %>"
          data-walkthrough-slide="<%= stepIndex %>"
          aria-hidden="<%= stepIndex === 0 ? 'false' : 'true' %>"
        >
          <div class="walkthrough-slide__copy">
            <div class="walkthrough-slide__topline">
              <span class="eyebrow"><%= step.stepLabel %></span>
              <span class="walkthrough-pill"><%= step.badgeText %></span>
            </div>
            <h4><%= step.title %></h4>
            <p><%= step.summary %></p>
          </div>

          <div class="walkthrough-browser">
            <div class="walkthrough-browser__topbar">
              <div class="walkthrough-browser__lights" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="walkthrough-browser__url">
                <span>vote.jhimssoftware.com</span>
                <small><%= step.route %></small>
              </div>
            </div>

            <div class="walkthrough-browser__body">
              <% if (step.key === "login") { %>
                <div class="demo-screen-card demo-screen-card--auth">
                  <div class="demo-screen-card__header">
                    <strong><%= step.screenTitle %></strong>
                    <span>Secure verification</span>
                  </div>

                  <div class="demo-field">
                    <span>Staff ID</span>
                    <strong>STF0234</strong>
                  </div>

                  <div class="demo-field">
                    <span>Phone Number</span>
                    <strong>024 123 4567</strong>
                  </div>

                  <button class="demo-button demo-button--primary" type="button">
                    <%= step.primaryButtonLabel %>
                  </button>

                  <p class="demo-screen-card__note"><%= step.secondaryCopy %></p>
                </div>
              <% } else if (step.key === "otp") { %>
                <div class="demo-screen-card demo-screen-card--otp">
                  <div class="demo-screen-card__header">
                    <strong>Phone Verification</strong>
                    <span>OTP required</span>
                  </div>

                  <p class="demo-screen-card__note">
                    Code sent to <strong><%= step.maskedPhone %></strong>
                  </p>

                  <div class="demo-otp-grid" aria-hidden="true">
                    <% step.otpDigits.forEach((digit) => { %>
                      <span><%= digit %></span>
                    <% }) %>
                  </div>

                  <div class="demo-button-row">
                    <button class="demo-button demo-button--primary" type="button">Verify and Continue</button>
                    <button class="demo-button demo-button--ghost" type="button">Resend OTP</button>
                  </div>
                </div>
              <% } else if (step.key === "ballot") { %>
                <div class="demo-screen-card demo-screen-card--ballot">
                  <div class="demo-progress">
                    <div>
                      <span><%= step.stepLabel %> of <%= step.totalPositions %></span>
                      <strong><%= step.currentPositionName %></strong>
                    </div>
                    <div class="demo-progress__meter">
                      <span style="width: <%= step.progressPercent %>%"></span>
                    </div>
                  </div>

                  <div class="demo-candidate-list">
                    <% step.candidates.forEach((candidate) => { %>
                      <div class="demo-candidate <%= candidate.name === step.selectedCandidateName ? 'demo-candidate--selected' : '' %>">
                        <% if (candidate.photoPath) { %>
                          <img src="<%= candidate.photoPath %>" alt="<%= candidate.name %>" />
                        <% } else { %>
                          <div class="demo-candidate__avatar"><%= candidate.initials %></div>
                        <% } %>

                        <div class="demo-candidate__copy">
                          <strong><%= candidate.name %></strong>
                          <span><%= candidate.bio || `${step.currentPositionName} candidate` %></span>
                        </div>
                      </div>
                    <% }) %>
                  </div>

                  <div class="demo-button-row">
                    <button class="demo-button demo-button--ghost" type="button">Skip Position</button>
                    <button class="demo-button demo-button--primary" type="button">Next Position</button>
                  </div>
                </div>
              <% } else if (step.key === "review") { %>
                <div class="demo-screen-card demo-screen-card--review">
                  <div class="demo-screen-card__header">
                    <strong>Final Review</strong>
                    <span>Check before submit</span>
                  </div>

                  <div class="demo-review-list">
                    <% step.selections.forEach((selection) => { %>
                      <div class="demo-review-row">
                        <div>
                          <strong><%= selection.positionName %></strong>
                          <span><%= selection.statusMeta %></span>
                        </div>
                        <em class="<%= selection.isSkipped ? 'demo-review-row__status demo-review-row__status--skipped' : 'demo-review-row__status' %>">
                          <%= selection.statusLabel %>
                        </em>
                      </div>
                    <% }) %>
                  </div>

                  <div class="demo-button-row">
                    <button class="demo-button demo-button--ghost" type="button">Go Back</button>
                    <button class="demo-button demo-button--primary" type="button">Yes, Submit</button>
                  </div>
                </div>
              <% } else if (step.key === "complete") { %>
                <div class="demo-screen-card demo-screen-card--complete">
                  <div class="demo-success-mark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                      <path d="M9.55 16.8 5.7 12.95l1.4-1.4 2.45 2.45 7.35-7.35 1.4 1.4-8.75 8.75Z" fill="currentColor"/>
                    </svg>
                  </div>
                  <strong class="demo-success-title">Ballot recorded successfully</strong>
                  <p class="demo-screen-card__note">
                    Thank you <strong><%= step.receiptName %></strong>. Your vote was saved on
                    <strong><%= step.receiptTime %></strong>.
                  </p>

                  <div class="demo-button-row demo-button-row--center">
                    <button class="demo-button demo-button--primary" type="button">Finish Session</button>
                  </div>
                </div>
              <% } %>
            </div>
          </div>

          <div class="walkthrough-slide__footer">
            <p><%= step.helperText %></p>
          </div>
        </article>
      <% }) %>
    </div>

    <aside class="walkthrough-sidebar">
      <div class="walkthrough-sidebar__header">
        <strong>Voting Demo Timeline</strong>
        <p>Click any step or let the demo play automatically.</p>
      </div>

      <div class="walkthrough-steps">
        <% voteWalkthrough.steps.forEach((step, stepIndex) => { %>
          <button
            class="walkthrough-step <%= stepIndex === 0 ? 'is-active' : '' %>"
            type="button"
            data-walkthrough-step="<%= stepIndex %>"
          >
            <span class="walkthrough-step__index"><%= String(stepIndex + 1).padStart(2, "0") %></span>
            <span class="walkthrough-step__body">
              <strong><%= step.title %></strong>
              <small><%= step.summary %></small>
            </span>
          </button>
        <% }) %>
      </div>

      <div class="walkthrough-sidebar__footer">
        <button
          class="button button-ghost button-small"
          type="button"
          data-walkthrough-toggle
          data-play-label="Play Demo"
          data-pause-label="Pause Demo"
        >
          Pause Demo
        </button>
        <a class="button button-small" href="#vote-guide-inline">Read Written Guide</a>
      </div>
    </aside>
  </div>
</section>

<section class="panel panel-light stack-lg" id="vote-guide-inline">
  <div class="section-heading">
    <div>
      <span class="eyebrow">How To Vote</span>
      <h3>Step-by-step voting guide for staff</h3>
    </div>
    <a class="button button-ghost button-small" href="/vote/login">Back to Voter Login</a>
  </div>

  <ol class="flow-list">
    <li>Open the voter portal when voting is open.</li>
    <li>Enter your staff ID and the same phone number that was registered for you.</li>
    <li>After successful verification, the ballot opens for you.</li>
    <li>Select one candidate for a position, or skip the position if you do not want to vote there.</li>
    <li>Click next to continue through the remaining positions one after another.</li>
    <li>Review your selections on the confirmation page before final submission.</li>
    <li>Submit your vote once. After submission, you cannot change it or vote again.</li>
  </ol>

  <div class="feature-grid guide-feature-grid">
    <article class="feature-card">
      <h4>Before you start</h4>
      <p>Make sure voting is open and your phone number matches the one stored in the system.</p>
    </article>
    <article class="feature-card">
      <h4>During voting</h4>
      <p>Read each position carefully and move through the ballot step by step until you reach the review page.</p>
    </article>
    <article class="feature-card">
      <h4>After submitting</h4>
      <p>The system marks you as voted immediately, so you cannot re-enter to cast another ballot.</p>
    </article>
  </div>
</section>

<%- include("partials/public-shell-end") %>
