<%- include("partials/public-shell-start", { pageTitle }) %>

<%
  const opensAtMs = settings.opensAt ? Date.parse(settings.opensAt) : Number.NaN;
  const closesAtMs = settings.closesAt ? Date.parse(settings.closesAt) : Number.NaN;
  const loginCountdownTarget = electionState.isScheduled
    ? opensAtMs
    : electionState.isOpen
      ? closesAtMs
      : Number.NaN;
  const hasLoginCountdown = Number.isFinite(loginCountdownTarget) && loginCountdownTarget > 0;
  const loginCountdownTitle = electionState.isScheduled ? 'Voting opens in' : 'Voting closes in';
  const loginCountdownEndedLabel = electionState.isScheduled ? 'Voting is now open' : 'Voting has closed';
  const loginCountdownNote = electionState.isScheduled
    ? 'The portal unlocks automatically at the official opening time.'
    : 'Finish your ballot before the official closing time.';
  const voteStatusTitle = electionState.isOpen
    ? 'Voting is live now.'
    : electionState.isScheduled
      ? 'Voting opens soon.'
      : electionState.isClosed
        ? 'Voting has closed.'
        : 'Election setup is still in progress.';
  const voteStatusMessage = electionState.isOpen
    ? 'Use your registered details below to enter the ballot securely.'
    : electionState.message;
%>

<section class="vote-entry-page">
  <article class="vote-entry-shell">
    <div class="vote-entry-shell__glow vote-entry-shell__glow--cyan"></div>
    <div class="vote-entry-shell__glow vote-entry-shell__glow--amber"></div>
    <div class="vote-entry-shell__pattern" aria-hidden="true"></div>

    <div class="vote-entry-grid">
      <section class="vote-entry-copy">
        <h1>
          Vote with
          <span>confidence.</span>
        </h1>

        <p>
          Sign in with your staff ID and registered phone number to access the ballot.
          The portal keeps the process verified, confidential, and simple.
        </p>

        <div class="vote-entry-points">
          <article class="vote-entry-point">
            <span class="vote-entry-point__icon vote-entry-point__icon--teal" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M12 2 4 5.5v5.22c0 5.18 3.42 9.99 8 11.28 4.58-1.29 8-6.1 8-11.28V5.5L12 2Zm-1.07 13.82L7.76 12.65l1.41-1.41 1.76 1.76 4.24-4.24 1.41 1.41-5.65 5.65Z" fill="currentColor"/>
              </svg>
            </span>
            <div>
              <strong>One secure ballot</strong>
              <span>Each voter can submit only once.</span>
            </div>
          </article>

          <article class="vote-entry-point">
            <span class="vote-entry-point__icon vote-entry-point__icon--blue" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M17 2H7a2 2 0 0 0-2 2v16l7-3 7 3V4a2 2 0 0 0-2-2Zm-5 12a4 4 0 1 1 0-8 4 4 0 0 1 0 8Z" fill="currentColor"/>
              </svg>
            </span>
            <div>
              <strong>Verified access</strong>
              <span>Only registered staff records can continue.</span>
            </div>
          </article>

          <article class="vote-entry-point">
            <span class="vote-entry-point__icon vote-entry-point__icon--amber" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M12 3a9 9 0 1 0 9 9 9.01 9.01 0 0 0-9-9Zm1 9.59 3.3 3.3-1.41 1.41L11 13V7h2Z" fill="currentColor"/>
              </svg>
            </span>
            <div>
              <strong>Fast voting flow</strong>
              <span>Move through the ballot one position at a time.</span>
            </div>
          </article>
        </div>

        <div class="vote-entry-status">
          <div class="vote-entry-status__topline">
            <span class="status-badge <%= electionState.badgeClass %>">
              <span class="status-dot"></span>
              <%= electionState.badgeLabel %>
            </span>
          </div>

          <strong><%= voteStatusTitle %></strong>
          <p><%= voteStatusMessage %></p>
        </div>
      </section>

      <article class="vote-entry-card">
        <div class="vote-entry-card__header">
          <h2>Voter Login</h2>
          <p>
            <%= otpEnabled
              ? 'Enter your details to receive a one-time verification code.'
              : 'Enter your details to continue directly to the ballot.' %>
          </p>
        </div>

        <form class="stack-md" action="/vote/login" method="post">
          <label class="field field--icon vote-entry-field">
            <span>Staff ID</span>
            <div class="field__control">
              <span class="field__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-3.31 0-6 1.79-6 4v1h12v-1c0-2.21-2.69-4-6-4Z" fill="currentColor"/>
                </svg>
              </span>
              <input name="staffId" placeholder="e.g. STF0234" required />
            </div>
          </label>

          <label class="field field--icon vote-entry-field">
            <span>Phone Number</span>
            <div class="field__control">
              <span class="field__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M7.05 4.5h2.1c.38 0 .71.26.8.63l.72 2.88a.84.84 0 0 1-.21.79l-1.37 1.37a13.53 13.53 0 0 0 4.74 4.74l1.37-1.37a.84.84 0 0 1 .79-.21l2.88.72c.37.09.63.42.63.8v2.1c0 .47-.38.85-.85.85A14.65 14.65 0 0 1 6.2 5.35c0-.47.38-.85.85-.85Z" fill="currentColor"/>
                </svg>
              </span>
              <input name="phoneNumber" placeholder="e.g. 024 123 4567" required />
            </div>
          </label>

          <button class="button vote-entry-card__submit" type="submit" <%= electionState.isOpen ? '' : 'disabled' %>>
            <%= otpEnabled ? 'Send OTP Code' : 'Continue to Ballot' %>
          </button>
        </form>

        <div class="vote-entry-card__footer">
          <span class="vote-entry-card__footer-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M17 8h-1V6a4 4 0 1 0-8 0v2H7a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2Zm-6 0V6a2 2 0 1 1 4 0v2h-4Z" fill="currentColor"/>
            </svg>
          </span>
          <p>
            <%= otpEnabled
              ? 'A verification code will be sent to the phone number registered for your staff record.'
              : 'Your ballot will open immediately after your details are matched successfully.' %>
          </p>
        </div>

        <% if (!electionState.isOpen) { %>
          <p class="note-block vote-entry-card__notice"><%= electionState.message %></p>
        <% } %>
      </article>
    </div>

    <div class="vote-entry-info-grid <%= hasLoginCountdown ? '' : 'vote-entry-info-grid--single' %>">
      <% if (hasLoginCountdown) { %>
        <article
          class="vote-countdown-panel"
          data-countdown-root
          data-countdown-target="<%= loginCountdownTarget %>"
          data-countdown-ended-label="<%= loginCountdownEndedLabel %>"
        >
          <div class="vote-countdown-panel__header">
            <div>
              <strong data-countdown-title><%= hasLoginCountdown ? loginCountdownTitle : 'Countdown pending' %></strong>
              <small data-countdown-copy><%= hasLoginCountdown ? loginCountdownNote : 'The election committee will publish the official timing here.' %></small>
            </div>
          </div>

          <div class="vote-countdown-board" aria-live="polite" aria-atomic="true">
            <div class="vote-countdown-tile">
              <strong data-countdown-days><%= hasLoginCountdown ? '00' : '--' %></strong>
              <span>Days</span>
            </div>
            <div class="vote-countdown-tile">
              <strong data-countdown-hours><%= hasLoginCountdown ? '00' : '--' %></strong>
              <span>Hours</span>
            </div>
            <div class="vote-countdown-tile">
              <strong data-countdown-minutes><%= hasLoginCountdown ? '00' : '--' %></strong>
              <span>Minutes</span>
            </div>
            <div class="vote-countdown-tile">
              <strong data-countdown-seconds><%= hasLoginCountdown ? '00' : '--' %></strong>
              <span>Seconds</span>
            </div>
          </div>
        </article>
      <% } %>

      <article class="vote-window-panel">
        <div class="vote-window-panel__header">
          <strong>Election Window</strong>
          <small>All times are in GMT</small>
        </div>

        <dl class="vote-window-panel__list">
          <div>
            <dt>Opens</dt>
            <dd><%= settings.opensAt ? formatDateTime(settings.opensAt) : 'Not scheduled yet' %></dd>
          </div>
          <div>
            <dt>Closes</dt>
            <dd><%= settings.closesAt ? formatDateTime(settings.closesAt) : 'Not scheduled yet' %></dd>
          </div>
        </dl>
      </article>
    </div>
  </article>
</section>

<%- include("partials/public-shell-end") %>
