<%- include("partials/admin-shell-start", {
  pageTitle,
  pageHeading: "Election Results",
  pageIntro,
  currentSection: "results"
}) %>

<section class="metric-grid">
  <article class="metric-card">
    <span>Total Voters</span>
    <strong><%= metrics.totalVoters %></strong>
  </article>
  <article class="metric-card">
    <span>Votes Cast</span>
    <strong><%= metrics.votedCount %></strong>
  </article>
  <article class="metric-card">
    <span>Turnout</span>
    <strong><%= metrics.totalVoters ? formatPercent(metrics.votedCount / metrics.totalVoters) : '0.0%' %></strong>
  </article>
</section>

<% if (resultsLocked) { %>
  <section class="panel panel-light narrow-panel stack-md">
    <span class="eyebrow">Results Waiting</span>
    <h2>Detailed statistics appear once the election opens.</h2>
    <p>
      Once voting starts, this page will show live provisional totals, chart bars, and turnout
      progress for administrators.
    </p>
  </section>
<% } else { %>
  <section class="panel panel-light">
    <div class="section-heading">
      <div>
        <span class="eyebrow"><%= isLiveResults ? 'Live Monitoring' : 'Export & Archive' %></span>
        <h2><%= isLiveResults ? 'Running statistics while voting continues' : 'Final results and next election reset' %></h2>
      </div>
      <div class="button-row">
        <% if (!isLiveResults) { %>
          <a class="button" href="/admin/results/pdf">Export PDF</a>
          <a class="button button-ghost" href="/admin/results/print" target="_blank" rel="noopener noreferrer">
            Print Results
          </a>
        <% } %>
      </div>
    </div>

    <div class="stack-md">
      <div class="info-row">
        <span>Turnout progress</span>
        <strong><%= metrics.totalVoters ? formatPercent(metrics.votedCount / metrics.totalVoters) : '0.0%' %></strong>
      </div>
      <div class="chart-meter chart-meter--turnout">
        <span
          class="chart-meter__fill chart-meter__fill--leading"
          style="width: <%= metrics.totalVoters ? (metrics.votedCount / metrics.totalVoters) * 100 : 0 %>%"
        ></span>
      </div>
      <% if (isLiveResults) { %>
        <p class="note-block results-live-note">
          Live results are provisional and this page refreshes automatically every 30 seconds while voting is open.
        </p>
      <% } else if (canArchiveReset) { %>
        <form
          class="stack-sm"
          action="/admin/election/archive-reset"
          method="post"
          onsubmit="return confirm('This will save the current election results and reset voters, positions, candidates, and ballots for the next election. Continue?');"
        >
          <button class="button button-danger" type="submit">Archive Results & Reset System</button>
          <p class="note-block">
            This keeps the finished election in the archive and clears the current working election so a new one can be prepared.
          </p>
        </form>
      <% } %>
    </div>
  </section>

  <%- include("partials/results-panels", { results, eyebrowLabel: isLiveResults ? 'Live Position Results' : 'Final Position Results' }) %>
<% } %>

<% if (isLiveResults) { %>
  <script>
    window.setTimeout(() => {
      window.location.reload();
    }, 30000);
  </script>
<% } %>

<%- include("partials/admin-shell-end") %>
