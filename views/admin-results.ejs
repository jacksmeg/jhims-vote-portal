<%- include("partials/admin-shell-start", {
  pageTitle,
  pageHeading: "Election Results",
  pageIntro,
  currentSection: "results"
}) %>

<% if (resultsLocked) { %>
  <section class="panel panel-light narrow-panel stack-md">
    <span class="eyebrow">Results Waiting</span>
    <h2>Detailed statistics appear once the election opens.</h2>
    <p>
      Once voting starts, this page will switch into live monitoring mode with turnout movement,
      position standings, and printable summaries for the committee.
    </p>
  </section>
<% } else { %>
  <%- include("partials/results-summary", {
    metrics,
    generatedAt,
    nonVoters,
    resultsStatusLabel
  }) %>

  <section class="panel panel-light stack-lg results-command-panel">
    <div class="results-command-panel__header">
      <div>
        <span class="eyebrow"><%= isLiveResults ? 'Live Monitoring' : 'Final Results Control' %></span>
        <h2><%= isLiveResults ? 'Running statistics while voting continues' : 'Print, export, and archive this election' %></h2>
        <p>
          <%= isLiveResults
            ? 'Track turnout and candidate standings in real time while ballots are still being submitted.'
            : 'Prepare polished printed records, export the formal report, and archive the election when everything is ready.' %>
        </p>
      </div>

      <div class="results-command-panel__actions">
        <% if (isLiveResults) { %>
          <div class="results-status-pill results-status-pill--live">
            <span class="status-dot"></span>
            <span>Auto refresh every 30 seconds</span>
          </div>
        <% } else { %>
          <a class="button" href="/admin/results/pdf">Export PDF</a>
          <a class="button button-ghost" href="/admin/results/print" target="_blank" rel="noopener noreferrer">
            Print Results
          </a>
        <% } %>
      </div>
    </div>

    <div class="results-command-grid">
      <article class="results-command-card">
        <span>Report Status</span>
        <strong><%= isLiveResults ? 'Provisional Monitoring' : 'Final Locked Results' %></strong>
        <small><%= resultsStatusLabel %> totals generated at <%= formatDateTime(generatedAt) %></small>
      </article>

      <article class="results-command-card">
        <span>Turnout Progress</span>
        <strong><%= metrics.totalVoters ? formatPercent(metrics.votedCount / metrics.totalVoters) : '0.0%' %></strong>
        <small><%= metrics.votedCount.toLocaleString() %> of <%= metrics.totalVoters.toLocaleString() %> registered voters cast ballots</small>
      </article>

      <article class="results-command-card">
        <span>Election Window</span>
        <strong><%= isLiveResults ? 'Still Open' : 'Closed' %></strong>
        <small><%= isLiveResults ? 'Standings remain provisional until the ballot closes.' : 'Printable records and archiving are available.' %></small>
      </article>
    </div>

    <% if (isLiveResults) { %>
      <div class="note-block results-live-note">
        Live results are provisional and this page refreshes automatically every 30 seconds while voting remains open.
      </div>
    <% } else if (canArchiveReset) { %>
      <div class="results-sms-control">
        <div class="results-sms-control__header">
          <div>
            <span class="eyebrow">Voter SMS Broadcast</span>
            <h3>Send provisional results to registered voters</h3>
            <p>
              Uses your saved Arkesel sender
              <strong><%= resultsSms.senderId || 'not configured' %></strong>
              to text each unique voter phone number after the election closes.
            </p>
          </div>
          <div class="results-sms-control__badge <%= resultsSms.configured ? 'is-ready' : 'is-warning' %>">
            <%= resultsSms.configured ? (resultsSms.autoEnabled ? 'Auto SMS On' : 'Arkesel Ready') : 'Setup Needed' %>
          </div>
        </div>

        <div class="results-sms-control__stats">
          <span><strong><%= resultsSms.recipientCount.toLocaleString() %></strong> recipients</span>
          <span><strong><%= resultsSms.duplicateCount.toLocaleString() %></strong> duplicate phones skipped</span>
          <span><strong><%= resultsSms.invalidCount.toLocaleString() %></strong> invalid phones skipped</span>
        </div>

        <form class="results-sms-control__settings" action="/admin/results/sms-settings" method="post">
          <input type="hidden" name="returnTo" value="/admin/results" />
          <label class="results-sms-control__confirm">
            <input type="checkbox" name="autoEnabled" <%= resultsSms.autoEnabled ? 'checked' : '' %> />
            <span>Automatically send provisional results SMS once voting closes</span>
          </label>
          <button class="button button-ghost" type="submit">Save Auto SMS Setting</button>
        </form>

        <label class="field results-sms-control__preview">
          <span>SMS preview</span>
          <textarea rows="4" readonly><%= resultsSms.messagePreview %></textarea>
        </label>

        <% if (resultsSms.lastSentAt) { %>
          <p class="note-block">
            Last send: <strong><%= formatDateTime(resultsSms.lastSentAt) %></strong>.
            Successful: <strong><%= resultsSms.lastSuccessCount.toLocaleString() %></strong>.
            Failed: <strong><%= resultsSms.lastFailureCount.toLocaleString() %></strong>.
          </p>
        <% } %>
        <% if (resultsSms.autoLastAttemptAt) { %>
          <p class="note-block">
            Last automatic attempt: <strong><%= formatDateTime(resultsSms.autoLastAttemptAt) %></strong>.
          </p>
        <% } %>

        <% if (!resultsSms.configured) { %>
          <p class="note-block">
            Add your Arkesel API key and sender ID under OTP settings before sending result SMS.
          </p>
        <% } else if (resultsSms.alreadySentForCurrentResults) { %>
          <p class="note-block">
            These exact results have already been sent. Tick the confirmation box below only if you want to resend them.
          </p>
        <% } %>

        <form
          class="stack-sm"
          action="/admin/results/sms"
          method="post"
          onsubmit="return confirm('Send provisional results SMS to registered voters now? This will use Arkesel SMS credit.');"
        >
          <% if (resultsSms.alreadySentForCurrentResults) { %>
            <label class="results-sms-control__confirm">
              <input type="checkbox" name="confirmResend" />
              <span>I understand these results were already sent and I want to resend them.</span>
            </label>
          <% } %>
          <button class="button" type="submit" <%= !resultsSms.canSend ? 'disabled' : '' %>>
            Send Provisional Results SMS
          </button>
        </form>
      </div>

      <form
        class="stack-sm"
        action="/admin/election/archive-reset"
        method="post"
        onsubmit="return confirm('This will save the current election results and reset voters, positions, candidates, and ballots for the next election. Continue?');"
      >
        <button class="button button-danger" type="submit">Archive Results & Reset System</button>
        <p class="note-block">
          This stores the completed election in the archive, then clears the current workspace so a fresh election can be prepared.
        </p>
      </form>
    <% } %>
  </section>

  <%- include("partials/results-panels", { results, eyebrowLabel: isLiveResults ? 'Live Position Results' : 'Final Position Results' }) %>
  <%- include("partials/results-declaration", { generatedAt, declarationLabel }) %>
<% } %>

<% if (isLiveResults) { %>
  <script>
    window.setTimeout(() => {
      window.location.reload();
    }, 30000);
  </script>
<% } %>

<%- include("partials/admin-shell-end") %>
