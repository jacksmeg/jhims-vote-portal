<%- include("partials/public-shell-start", { pageTitle }) %>

<section class="split-stage">
  <div class="panel panel-dark stack-lg">
    <span class="eyebrow">Nomination Status</span>
    <h2>Check your nomination with your application number.</h2>
    <p>
      After you submit a nomination, the system gives you an official application number.
      Use that number here to follow committee decisions and continue any correction request.
    </p>

    <div class="check-list">
      <div>Each submitted nomination gets its own application number</div>
      <div>The same number is used later for status tracking and corrections</div>
      <div>Committee approval is required before anyone reaches the ballot</div>
      <div>New applications close automatically once voting starts</div>
    </div>
  </div>

  <div class="panel panel-light stack-lg narrow-panel">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Status Check</span>
        <h3>Open your nomination record</h3>
      </div>
      <p class="muted-text">Track progress</p>
    </div>

    <form class="stack-md" action="/nomination/status/login" method="post">
      <label class="field">
        <span>Application Number</span>
        <input name="applicationNumber" placeholder="APP-8K4P-21QX" required />
      </label>

      <button class="button" type="submit">Check Status</button>
    </form>

    <p class="note-block">Status remains available even after the nomination window closes.</p>
  </div>
</section>

<%- include("partials/public-shell-end") %>
