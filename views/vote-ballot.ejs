<%- include("partials/public-shell-start", { pageTitle }) %>

<div class="vote-flow-container vote-flow-container--ballot">
  <%- include("partials/vote-flow-steps", { currentStep: 3, allComplete: false }) %>

  <section class="ballot-redesign-panel">
    <header class="ballot-redesign-panel__header">
      <div>
        <h1><%= currentPosition.name %></h1>
        <p>Position <%= currentStep %> of <%= totalSteps %> <span></span> Completed selections: <strong><%= completedSteps %> of <%= totalSteps %></strong></p>
      </div>
      <div class="ballot-overall-progress">
        <div><span style="width: <%= progressPercent %>%"></span></div>
        <p><strong><%= Math.round(progressPercent) %>%</strong><small>Overall Progress</small></p>
      </div>
    </header>

    <div class="ballot-redesign-panel__instruction">
      <svg viewBox="0 0 24 24"><path d="M8 11V5a2 2 0 0 1 4 0v5-3a2 2 0 0 1 4 0v4-2a2 2 0 0 1 4 0v5c0 4-3 7-7 7h-1c-2.5 0-4.6-1.2-6-3L3 14a2 2 0 0 1 3-2l2 2"/></svg>
      Vote for one candidate, or skip this position.
      <span class="ballot-voter-chip">Voter ID <strong><%= voter.staffId %></strong></span>
    </div>

    <% if (isSkippedSelection) { %><p class="ballot-skip-notice">This position is currently marked as skipped. Select a candidate to replace the skipped choice.</p><% } %>

    <form action="/vote/step/<%= currentStep %>" method="post" class="ballot-redesign-form">
      <div class="ballot-candidate-grid">
        <% currentPosition.candidates.forEach((candidate, candidateIndex) => { %>
          <% const candidateTone = ['blue', 'pink', 'yellow', 'green'][candidateIndex % 4]; %>
          <label class="ballot-candidate-card is-<%= candidateTone %> <%= selectedCandidateId === candidate.id ? 'is-selected' : '' %>">
            <input type="radio" name="candidateId" value="<%= candidate.id %>" <%= selectedCandidateId === candidate.id ? 'checked' : '' %> />
            <span class="ballot-candidate-card__number"><%= candidateIndex + 1 %></span>
            <span class="ballot-candidate-card__photo">
              <span class="ballot-candidate-card__fallback"><%= getInitials(candidate.name) %></span>
              <% if (candidate.photoPath) { %><img src="<%= candidate.photoPath %>" alt="<%= candidate.name %>" loading="eager" decoding="async" fetchpriority="high" data-image-fallback /><% } %>
            </span>
            <span class="ballot-candidate-card__copy"><strong><%= candidate.name %></strong><small><%= currentPosition.name %> candidate</small></span>
            <span class="ballot-candidate-card__choice"><svg viewBox="0 0 24 24"><path d="m6 12 4 4 8-9"/></svg></span>
          </label>
        <% }) %>
      </div>

      <div class="ballot-action-bar">
        <% if (currentStep > 1) { %><a href="/vote/step/<%= currentStep - 1 %>"><svg viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>Back</a><% } else { %><a href="/"><svg viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>Cancel</a><% } %>
        <button class="ballot-skip-button" type="submit" name="action" value="skip"><svg viewBox="0 0 24 24"><path d="m7 6 10 6-10 6V6Z"/><path d="M18 6v12"/></svg><%= isLastStep ? 'Skip and Review' : 'Skip Position' %></button>
        <button class="ballot-next-button" type="submit" name="action" value="select"><%= isLastStep ? 'Review Ballot' : 'Next Position' %><svg viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></button>
      </div>
    </form>
  </section>
</div>

<%- include("partials/public-shell-end") %>
