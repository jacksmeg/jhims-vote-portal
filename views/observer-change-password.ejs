<%- include("partials/head", { pageTitle, bodyClass: "observer-login-body observer-password-body" }) %>

<main class="observer-password-page">
  <section class="observer-password-card">
    <a class="observer-password-brand" href="/"><% if (settings.organizationLogoPath) { %><img src="<%= settings.organizationLogoPath %>" alt="<%= settings.electionName %> logo" /><% } else { %><span>EO</span><% } %><div><strong><%= settings.electionName %></strong><small>Observer Access</small></div></a>
    <%- include("partials/flash") %>
    <div class="observer-password-icon"><svg viewBox="0 0 24 24"><rect x="4" y="10" width="16" height="11" rx="3"/><path d="M8 10V7a4 4 0 0 1 8 0v3M12 14v3"/></svg></div>
    <h1>Create your private password</h1>
    <p>Hello <strong><%= account.fullName %></strong>. Replace the temporary password before opening the read-only dashboard.</p>
    <form action="/observer/change-password" method="post" class="observer-password-form">
      <label><span>New Password</span><input name="password" type="password" autocomplete="new-password" minlength="10" required /></label>
      <label><span>Confirm Password</span><input name="passwordConfirmation" type="password" autocomplete="new-password" minlength="10" required /></label>
      <ul><li>At least 10 characters</li><li>Uppercase and lowercase letters</li><li>A number and a symbol</li></ul>
      <button type="submit">Save Password &amp; Open Dashboard</button>
    </form>
    <form action="/observer/logout" method="post"><button class="observer-password-cancel" type="submit">Cancel and sign out</button></form>
  </section>
</main>
</body>
</html>
