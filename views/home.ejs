<%- include("partials/public-shell-start", { pageTitle }) %>

<%
  const voterStatusInputValue = voterStatusLookup?.staffId || '';
%>

<section class="hero-grid">
  <div class="hero-copy panel panel-dark">
    <span class="eyebrow">Election Service App</span>
    <h2>Run voting, nominations, and election communication from one secure portal.</h2>
    <p>
      This portal verifies every voter, supports nomination submission for interested staff
      members through a direct online form, and gives the election committee a controlled dashboard for setup, monitoring,
      approvals, backups, and final results.
    </p>

    <div class="hero-actions">
      <a class="button" href="/vote/login">Vote Now</a>
      <a class="button button-ghost" href="/nomination/form">Apply for Nomination</a>
    </div>

    <div class="hero-stats">
      <div>
        <strong><%= metrics.totalVoters %></strong>
        <span>registered voters</span>
      </div>
      <div>
        <strong><%= metrics.totalBallots %></strong>
        <span>ballots submitted</span>
      </div>
      <div>
        <strong><%= metrics.totalPositions %></strong>
        <span>positions on ballot</span>
      </div>
    </div>
  </div>

  <div class="panel panel-light stack-lg">
    <div>
      <span class="eyebrow">How It Works</span>
      <h3>Simple access for voters, nominees, and the election committee.</h3>
    </div>

    <ol class="flow-list">
      <li>Registered staff can log in with staff ID and phone number.</li>
      <li>Voters access the ballot only once and submit securely.</li>
      <li>Interested applicants can open the nomination form directly and submit online.</li>
      <li>The election committee reviews, approves, and publishes nominees as candidates.</li>
      <li>Final results and archives remain controlled from the admin dashboard.</li>
    </ol>

    <div class="card-grid card-grid--compact">
      <article class="mini-card">
        <h4>Voting Window</h4>
        <p><%= electionState.message %></p>
      </article>
      <article class="mini-card">
        <h4>Nomination Window</h4>
        <p><%= nominationState.message %></p>
      </article>
      <article class="mini-card">
        <h4>Candidate Setup</h4>
        <p>Add positions, publish approved nominees, and manage the ballot centrally.</p>
      </article>
    </div>
  </div>
</section>

<section class="panel panel-light stack-lg">
  <div class="section-heading">
    <div>
      <span class="eyebrow">Portal Actions</span>
      <h3>Choose what you want to do.</h3>
    </div>
    <p>Every public action starts here, and each one follows its own secure workflow.</p>
  </div>

  <div class="action-card-grid">
    <a class="action-card" href="/vote/login">
      <span class="action-card__icon action-card__icon--vote" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M5 4h14a1 1 0 0 1 1 1v3H4V5a1 1 0 0 1 1-1Zm-1 6h16v9a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-9Zm3 2v2h2v-2H7Zm4 0v2h6v-2h-6Zm-4 4v2h2v-2H7Zm4 0v2h4v-2h-4Z" fill="currentColor"/>
        </svg>
      </span>
      <strong>Vote Now</strong>
      <p>Open the voter portal and submit your ballot for the current election.</p>
      <span class="action-card__meta"><%= electionState.badgeLabel %></span>
    </a>

    <a class="action-card" href="/nomination/form">
      <span class="action-card__icon action-card__icon--nomination" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 2 4 5.5v5.22c0 5.18 3.42 9.99 8 11.28 4.58-1.29 8-6.1 8-11.28V5.5L12 2Zm-1.07 13.82L7.76 12.65l1.41-1.41 1.76 1.76 4.24-4.24 1.41 1.41-5.65 5.65Z" fill="currentColor"/>
        </svg>
      </span>
      <strong>Apply for Nomination</strong>
      <p>Open the nomination form directly and submit your application online.</p>
      <span class="action-card__meta"><%= nominationState.badgeLabel %></span>
    </a>

    <a class="action-card" href="/nomination/status/login">
      <span class="action-card__icon action-card__icon--status" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 3a9 9 0 1 0 9 9 9.01 9.01 0 0 0-9-9Zm1 9.59 3.3 3.3-1.41 1.41L11 13V7h2Z" fill="currentColor"/>
        </svg>
      </span>
      <strong>Check Nomination Status</strong>
      <p>Review your nomination decision and continue any correction requested by the committee.</p>
      <span class="action-card__meta">Track progress</span>
    </a>

    <a class="action-card" href="#voter-status-panel">
      <span class="action-card__icon action-card__icon--status" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-3.31 0-6 1.79-6 4v1h12v-1c0-2.21-2.69-4-6-4Zm8-2h-2V7a2 2 0 0 0-2-2h-5V3h5a4 4 0 0 1 4 4v5Z" fill="currentColor"/>
        </svg>
      </span>
      <strong>Check Voter Status</strong>
      <p>Confirm that your staff record is uploaded and ready for voting with your staff ID.</p>
      <span class="action-card__meta">Public check</span>
    </a>
  </div>

  <div class="button-row">
    <a class="button button-ghost" href="/nomination/form/download">Download Nomination Form PDF</a>
  </div>
</section>

<section class="panel panel-light stack-lg voter-status-panel" id="voter-status-panel">
  <div class="section-heading">
    <div>
      <span class="eyebrow">Check Voter Status</span>
      <h3>Find your uploaded voter record before voting opens.</h3>
    </div>
    <p>Enter only your staff ID. The portal will confirm whether your voter details are already in the system.</p>
  </div>

  <div class="voter-status-grid">
    <form class="voter-status-form" action="/" method="get">
      <label class="field">
        <span>Staff ID</span>
        <input
          name="voterStatusStaffId"
          value="<%= voterStatusInputValue %>"
          placeholder="e.g. STF0234"
          required
        />
      </label>

      <button class="button" type="submit">Check My Status</button>
      <p class="voter-status-form__help">
        Your record will show your name, department, masked phone number, and whether you have voted already.
      </p>
    </form>

    <article class="voter-status-card">
      <% if (!voterStatusLookup) { %>
        <div class="voter-status-card__empty">
          <strong>No search yet</strong>
          <p>Enter your staff ID to check whether your voter record is already uploaded into the portal.</p>
        </div>
      <% } else if (voterStatusLookup.found) { %>
        <div class="voter-status-card__header">
          <span class="voter-status-pill <%= voterStatusLookup.statusToneClass %>"><%= voterStatusLookup.statusLabel %></span>
          <strong>Voter record found</strong>
        </div>

        <div class="voter-status-card__details">
          <div>
            <span>Full Name</span>
            <strong><%= voterStatusLookup.fullName %></strong>
          </div>
          <div>
            <span>Staff ID</span>
            <strong><%= voterStatusLookup.staffId %></strong>
          </div>
          <div>
            <span>Department</span>
            <strong><%= voterStatusLookup.department || 'Not recorded' %></strong>
          </div>
          <div>
            <span>Registered Phone</span>
            <strong><%= voterStatusLookup.maskedPhoneNumber || 'Not recorded' %></strong>
          </div>
          <div>
            <span>Voting Status</span>
            <strong><%= voterStatusLookup.hasVoted ? 'Already voted' : 'Not voted yet' %></strong>
          </div>
          <div>
            <span>Last Vote Time</span>
            <strong><%= voterStatusLookup.votedAt ? formatDateTime(voterStatusLookup.votedAt) : 'No vote recorded yet' %></strong>
          </div>
        </div>
      <% } else { %>
        <div class="voter-status-card__empty voter-status-card__empty--alert">
          <strong><%= voterStatusLookup.invalid ? 'Invalid staff ID' : 'Record not found' %></strong>
          <p><%= voterStatusLookup.message %></p>
        </div>
      <% } %>
    </article>
  </div>
</section>

<section class="panel panel-light">
  <div class="section-heading">
    <div>
      <span class="eyebrow">Important Safeguards</span>
      <h3>Built around your election rules.</h3>
    </div>
      <p>Voting still uses staff verification, while nominations use a controlled submission window and committee review workflow.</p>
  </div>

  <div class="feature-grid">
    <article class="feature-card">
      <h4>One staff member = one vote</h4>
      <p>Each registered record is checked and marked as voted after submission.</p>
    </article>
    <article class="feature-card">
      <h4>Protected nominations</h4>
      <p>Each nomination receives its own application number after submission, and duplicate nominations for the same staff ID and position are blocked.</p>
    </article>
    <article class="feature-card">
      <h4>Timed election windows</h4>
      <p>Admins control both voting and nomination opening/closing times from the dashboard.</p>
    </article>
    <article class="feature-card">
      <h4>Approval workflow</h4>
      <p>Nominations stay hidden from the ballot until the committee approves and publishes them as candidates.</p>
    </article>
  </div>
</section>

<%- include("partials/public-shell-end") %>
