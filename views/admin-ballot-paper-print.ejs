<%- include("partials/head", { pageTitle }) %>

<main class="print-page">
  <section class="print-toolbar">
    <div>
      <span class="eyebrow">Print Ballot Paper</span>
      <h1><%= position.name %></h1>
      <p>Preview the official ballot-paper style first. This local version is not uploaded yet.</p>
    </div>

    <div class="button-row">
      <button class="button" type="button" onclick="window.print()">Print Now</button>
      <a class="button button-ghost" href="/admin/positions/<%= position.id %>/ballot-paper/pdf">Download PDF</a>
      <a class="button button-ghost" href="/admin/ballot-layout#position-<%= position.id %>">Back to Ballot Layout</a>
    </div>
  </section>

  <section class="print-sheet ballot-paper-sheet ballot-paper-sheet--official">
    <header class="ballot-paper-sheet__masthead">
      <div class="ballot-paper-sheet__brand-panel">
        <% if (settings.organizationLogoPath) { %>
          <img class="ballot-paper-sheet__logo" src="<%= settings.organizationLogoPath %>" alt="<%= settings.electionName %> logo" />
        <% } else { %>
          <div class="candidate-avatar-fallback ballot-paper-sheet__logo-fallback">EC</div>
        <% } %>

        <div class="ballot-paper-sheet__brand-copy">
          <span class="eyebrow">Official Ballot Paper</span>
          <h2><%= settings.electionName %></h2>
          <p><strong>Position:</strong> <%= position.name %></p>
        </div>
      </div>

      <div class="ballot-paper-sheet__meta">
        <div class="winner-pill">Vote For One Candidate</div>
        <p><strong>Generated:</strong> <%= formatDateTime(generatedAt) %></p>
        <p>Put your mark in only one box below.</p>
      </div>
    </header>

    <section class="ballot-paper-table">
      <header class="ballot-paper-table__header">
        <span>Candidate Photo</span>
        <span>Candidate Name</span>
        <span>Mark Box</span>
      </header>

      <div class="stack-sm">
        <% position.candidates.forEach((candidate) => { %>
          <article class="ballot-paper-row">
            <div class="ballot-paper-row__photo">
              <% if (candidate.photoPath) { %>
                <img src="<%= candidate.photoPath %>" alt="<%= candidate.name %>" />
              <% } else { %>
                <div class="candidate-avatar-fallback candidate-avatar-fallback--large"><%= getInitials(candidate.name) %></div>
              <% } %>
            </div>

            <div class="ballot-paper-row__candidate">
              <strong><%= candidate.name.toUpperCase() %></strong>
              <span><%= position.name %></span>
            </div>

            <div class="ballot-paper-row__mark">
              <span aria-hidden="true"></span>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  </section>
</main>

</body>
</html>
