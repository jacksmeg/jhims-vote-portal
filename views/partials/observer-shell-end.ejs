    <%- include("footer-brand", { variant: "observer" }) %>
  </div>
</div>
<script>
  (() => {
    const menu = document.querySelector('[data-observer-menu]');
    const close = document.querySelector('[data-observer-menu-close]');
    const setOpen = (open) => {
      document.body.classList.toggle('observer-menu-open', open);
      menu?.setAttribute('aria-expanded', String(open));
    };
    menu?.addEventListener('click', () => setOpen(!document.body.classList.contains('observer-menu-open')));
    close?.addEventListener('click', () => setOpen(false));
    document.querySelectorAll('.observer-nav a').forEach((link) => link.addEventListener('click', () => setOpen(false)));
  })();

  document.querySelectorAll('img[data-image-fallback]').forEach((image) => {
    const hideBrokenImage = () => { image.hidden = true; image.style.display = 'none'; };
    image.addEventListener('error', hideBrokenImage, { once: true });
    if (image.complete && image.naturalWidth === 0) hideBrokenImage();
  });
</script>
</body>
</html>
