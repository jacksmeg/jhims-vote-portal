<section class="stack-lg">
  <% results.forEach((result) => { %>
    <article class="panel panel-light stack-md">
      <div class="section-heading">
        <div>
          <span class="eyebrow"><%= typeof eyebrowLabel === 'string' ? eyebrowLabel : 'Position Results' %></span>
          <h2><%= result.name %></h2>
          <p class="muted-text">
            Valid votes: <strong><%= result.totalVotes %></strong>
          </p>
        </div>

        <div class="stack-sm">
          <div class="winner-pill">Winner: <strong><%= result.winnerLabel %></strong></div>
          <div class="inline-badge inline-badge--info">Margin: <strong><%= result.marginLabel %></strong></div>
        </div>
      </div>

      <div class="position-result-grid">
        <% result.candidates.forEach((candidate) => { %>
          <article class="candidate-summary">
            <div class="candidate-summary__media">
              <% if (candidate.photoPath) { %>
                <img src="<%= candidate.photoPath %>" alt="<%= candidate.name %>" />
              <% } else { %>
                <div class="candidate-avatar-fallback"><%= getInitials(candidate.name) %></div>
              <% } %>
            </div>

            <div class="candidate-summary__body">
              <strong><%= candidate.name %></strong>
              <span><%= candidate.voteCount %> vote(s)</span>
              <small>
                <%= result.totalVotes ? formatPercent(candidate.shareRatio || 0) : '0.0%' %> of valid votes
              </small>
              <div class="chart-meter">
                <span
                  class="chart-meter__fill <%= candidate.isLeading ? 'chart-meter__fill--leading' : '' %>"
                  style="width: <%= Math.max((candidate.shareRatio || 0) * 100, candidate.voteCount > 0 ? 8 : 0) %>%"
                ></span>
              </div>
            </div>

            <div class="candidate-summary__actions">
              <% if (candidate.isLeading && result.totalVotes > 0) { %>
                <span class="winner-pill">Winner</span>
              <% } else { %>
                <span class="inline-badge inline-badge--muted">Candidate</span>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    </article>
  <% }) %>
</section>
