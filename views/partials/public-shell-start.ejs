<%- include("head", { pageTitle }) %>
<% const isVotePortal = currentPath.startsWith('/vote'); %>
<% const isNominationPortal = currentPath.startsWith('/nomination'); %>
<% const isPortalFlow = isVotePortal || isNominationPortal; %>
<% const isVoteLogin = currentPath === '/vote/login'; %>
<% const showVoteCountdown = isVotePortal && electionState.isOpen && voteClosesAtMs && !isVoteLogin; %>
<div class="site-shell">
  <header class="site-header <%= isPortalFlow ? 'site-header--portal' : '' %>">
    <a class="brand-mark" href="<%= isVotePortal ? '/vote/login' : isNominationPortal ? '/nomination/login' : '/' %>">
      <% if (settings.organizationLogoPath) { %>
        <img class="brand-mark__logo" src="<%= settings.organizationLogoPath %>" alt="<%= settings.electionName %> logo" />
      <% } else { %>
        <span class="brand-mark__crest">VP</span>
      <% } %>
      <span>
        <strong><%= settings.electionName %></strong>
        <small><%= isPortalFlow ? 'Election Portal' : 'Secure internal ballot system' %></small>
      </span>
    </a>

    <% if (isPortalFlow) { %>
      <div class="site-header__utility">
        <a
          class="site-utility-link"
          href="https://wa.me/233592934612"
          target="_blank"
          rel="noopener noreferrer"
        >
          Help Center
        </a>

        <div class="status-badge <%= electionState.badgeClass %>">
          <span class="status-dot"></span>
          <%= electionState.badgeLabel %>
        </div>
      </div>
    <% } else { %>
      <nav class="site-nav">
        <a class="<%= currentPath === '/' ? 'active' : '' %>" href="/">Home</a>
        <a class="<%= currentPath.startsWith('/vote') ? 'active' : '' %>" href="/vote/login">
          Vote
        </a>
      </nav>

      <div class="status-badge <%= electionState.badgeClass %>">
        <span class="status-dot"></span>
        <%= electionState.badgeLabel %>
      </div>
    <% } %>
  </header>

  <main class="site-main">
    <%- include("flash") %>

    <% if (showVoteCountdown) { %>
      <section
        class="countdown-banner"
        data-countdown-root
        data-countdown-target="<%= voteClosesAtMs %>"
        data-countdown-ended-label="Voting has closed"
      >
        <div class="countdown-banner__copy">
          <span class="eyebrow">Time Left to Vote</span>
          <h2 data-countdown-title>Voting closes in</h2>
          <p data-countdown-copy>
            Finish your ballot before
            <strong><%= formatDateTime(settings.closesAt) %></strong>.
          </p>
        </div>

        <div class="countdown-banner__timer" aria-live="polite" aria-atomic="true">
          <div class="countdown-unit">
            <strong data-countdown-days>00</strong>
            <span>Days</span>
          </div>
          <div class="countdown-unit">
            <strong data-countdown-hours>00</strong>
            <span>Hours</span>
          </div>
          <div class="countdown-unit">
            <strong data-countdown-minutes>00</strong>
            <span>Minutes</span>
          </div>
          <div class="countdown-unit">
            <strong data-countdown-seconds>00</strong>
            <span>Seconds</span>
          </div>
        </div>
      </section>
    <% } %>
