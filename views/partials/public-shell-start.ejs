<% const isHomePage = currentPath === '/'; %>
<%- include("head", { pageTitle, bodyClass: isHomePage ? "public-home-body" : "" }) %>
<% const isVotePortal = currentPath.startsWith('/vote'); %>
<% const isNominationPortal = currentPath.startsWith('/nomination'); %>
<% const isPortalFlow = isVotePortal || isNominationPortal; %>
<% const isVoteLogin = currentPath === '/vote/login'; %>
<% const showPortalHelpLink = !(isVoteLogin && isVotePortal); %>
<% const showVoteCountdown = isVotePortal && electionState.isOpen && voteClosesAtMs && !isVoteLogin; %>
<% const showNominationCountdown = currentPath === '/nomination/form' && nominationState.isScheduled && nominationOpensAtMs; %>
<%
  const homeHeaderTitle = 'UDEGHSWWA ELECTION 2026';
  const homeHeaderSubtitle = 'Election Portal';
  const homeHeaderStatusText = electionState.isOpen
    ? 'Live voting in progress'
    : electionState.isScheduled
      ? 'Auto-open enabled'
      : electionState.isClosed
        ? 'Results available'
        : 'Setup in progress';
%>
<%
  const portalHelpHref = isVotePortal
    ? '/vote/login#vote-guide-panel'
    : isNominationPortal
      ? '/nomination/form#nomination-guide-inline'
      : '/';
  const portalHelpLabel = isVotePortal ? 'How To Vote' : isNominationPortal ? 'How To Apply' : 'Help';
%>
<div class="site-shell">
  <header class="site-header <%= isPortalFlow ? 'site-header--portal' : 'site-header--home' %>">
    <a class="brand-mark" href="<%= isVotePortal ? '/vote/login' : isNominationPortal ? '/nomination/form' : '/' %>">
      <% if (settings.organizationLogoPath) { %>
        <img class="brand-mark__logo" src="<%= settings.organizationLogoPath %>" alt="<%= settings.electionName %> logo" />
      <% } else { %>
        <span class="brand-mark__crest">VP</span>
      <% } %>
      <span>
        <strong><%= isPortalFlow ? settings.electionName : homeHeaderTitle %></strong>
        <small><%= isPortalFlow ? 'Election Portal' : homeHeaderSubtitle %></small>
      </span>
    </a>

    <% if (isPortalFlow) { %>
      <div class="site-header__utility">
        <% if (showPortalHelpLink) { %>
          <a
            class="site-utility-link"
            href="<%= portalHelpHref %>"
          >
            <%= portalHelpLabel %>
          </a>
        <% } %>

        <div class="status-badge <%= electionState.badgeClass %>">
          <span class="status-dot"></span>
          <%= electionState.badgeLabel %>
        </div>
      </div>
    <% } else { %>
      <nav class="site-nav site-nav--home">
        <a class="<%= currentPath === '/' ? 'active' : '' %>" href="/">Home</a>
        <a href="#details-grid">Information</a>
        <a href="mailto:jacksmeg99@gmail.com">Contact</a>
      </nav>

      <div class="site-header__home-tools">
        <div class="site-header__status-card">
          <span class="site-header__status-label">Election Status</span>
          <div class="site-header__status-copy">
            <div class="status-badge <%= electionState.badgeClass %>">
              <span class="status-dot"></span>
              <%= electionState.badgeLabel %>
            </div>
            <small><%= homeHeaderStatusText %></small>
          </div>
        </div>

        <a class="site-header__quick-link" href="mailto:jacksmeg99@gmail.com">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Zm0 3 8 5 8-5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
          </svg>
          <span>Support</span>
        </a>
      </div>
    <% } %>
  </header>

  <main class="site-main">
    <%- include("flash") %>

    <% if (showVoteCountdown) { %>
      <section
        class="countdown-banner"
        data-countdown-root
        data-countdown-target="<%= voteClosesAtMs %>"
        data-countdown-ended-label="Voting has closed"
      >
        <div class="countdown-banner__copy">
          <h2 data-countdown-title>Time Remaining</h2>
          <p data-countdown-copy>
            Voting closes at
            <strong><%= formatDateTime(settings.closesAt) %></strong>.
          </p>
        </div>

        <div class="countdown-banner__timer" aria-live="polite" aria-atomic="true">
          <div class="countdown-unit">
            <strong data-countdown-days>00</strong>
            <span>Days</span>
          </div>
          <div class="countdown-unit">
            <strong data-countdown-hours>00</strong>
            <span>Hours</span>
          </div>
          <div class="countdown-unit">
            <strong data-countdown-minutes>00</strong>
            <span>Minutes</span>
          </div>
          <div class="countdown-unit">
            <strong data-countdown-seconds>00</strong>
            <span>Seconds</span>
          </div>
        </div>
      </section>
    <% } %>

    <% if (showNominationCountdown) { %>
      <section
        class="countdown-banner"
        data-countdown-root
        data-countdown-target="<%= nominationOpensAtMs %>"
        data-countdown-ended-label="Nominations are now open"
        data-countdown-ended-copy="Refreshing the form so submission can begin."
        data-countdown-end-reload="true"
      >
        <div class="countdown-banner__copy">
          <h2 data-countdown-title>Nomination Opens In</h2>
          <p data-countdown-copy>
            Submission starts at
            <strong><%= formatDateTime(settings.nominationOpensAt) %></strong>.
          </p>
        </div>

        <div class="countdown-banner__timer" aria-live="polite" aria-atomic="true">
          <div class="countdown-unit">
            <strong data-countdown-days>00</strong>
            <span>Days</span>
          </div>
          <div class="countdown-unit">
            <strong data-countdown-hours>00</strong>
            <span>Hours</span>
          </div>
          <div class="countdown-unit">
            <strong data-countdown-minutes>00</strong>
            <span>Minutes</span>
          </div>
          <div class="countdown-unit">
            <strong data-countdown-seconds>00</strong>
            <span>Seconds</span>
          </div>
        </div>
      </section>
    <% } %>
