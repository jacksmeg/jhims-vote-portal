<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      <%= pageTitle ? `${pageTitle} | ${settings.electionName}` : settings.electionName %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <% if (typeof captcha !== "undefined" && captcha.isEnabled && captcha.siteKey) { %>
      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <% } %>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>" data-theme="<%= settings.themeName || 'heritage' %>">
