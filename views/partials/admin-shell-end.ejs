        <svg viewBox="0 0 32 32" focusable="false">
          <path
            d="M16 3.2c-6.95 0-12.6 5.65-12.6 12.61 0 2.22.58 4.38 1.68 6.27L3 29l7.1-2.01a12.53 12.53 0 0 0 5.9 1.5h.01c6.95 0 12.6-5.65 12.6-12.61C28.61 8.85 22.96 3.2 16 3.2Zm0 22.95h-.01a10.4 10.4 0 0 1-5.29-1.45l-.38-.22-4.21 1.19 1.23-4.1-.24-.4a10.35 10.35 0 0 1-1.6-5.52c0-5.72 4.67-10.39 10.41-10.39 2.78 0 5.39 1.08 7.35 3.04a10.3 10.3 0 0 1 3.03 7.35c0 5.73-4.67 10.4-10.4 10.4Zm5.7-7.77c-.31-.16-1.86-.92-2.15-1.03-.29-.1-.5-.16-.7.16-.2.31-.8 1.03-.97 1.24-.18.2-.35.23-.66.08-.3-.16-1.28-.47-2.45-1.5-.9-.8-1.51-1.8-1.7-2.1-.17-.31-.02-.48.13-.63.13-.13.3-.35.45-.52.15-.18.2-.31.3-.52.1-.2.05-.39-.03-.55-.08-.16-.7-1.69-.96-2.31-.25-.61-.5-.53-.7-.54l-.6-.01c-.2 0-.52.08-.79.39-.27.32-1.04 1.02-1.04 2.49s1.07 2.88 1.22 3.08c.15.21 2.1 3.2 5.08 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.08 1.86-.76 2.12-1.49.26-.74.26-1.36.18-1.49-.08-.13-.28-.2-.59-.36Z"
