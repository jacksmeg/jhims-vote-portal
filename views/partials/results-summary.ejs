<%
  const turnoutRatio = metrics.totalVoters ? metrics.votedCount / metrics.totalVoters : 0;
  const turnoutWidth = `${Math.max(turnoutRatio * 100, metrics.votedCount > 0 ? 10 : 0)}%`;
  const reportToneClass = resultsStatusLabel === 'Final' ? 'results-status-pill--final' : 'results-status-pill--live';
%>

<section class="panel panel-light stack-lg results-overview-panel">
  <div class="results-overview-hero">
    <div class="results-overview-hero__copy">
      <span class="eyebrow">Official Results Summary</span>
      <h2><%= settings.electionName %></h2>
      <p>
        Results generated on <strong><%= formatDateTime(generatedAt) %></strong>.
        Voting opened on <strong><%= formatDateTime(settings.opensAt) %></strong> and
        closed on <strong><%= formatDateTime(settings.closesAt) %></strong>.
      </p>
    </div>

    <div class="results-overview-hero__side">
      <div class="results-status-pill <%= reportToneClass %>">
        <span class="status-dot"></span>
        <span><%= resultsStatusLabel %> Results</span>
      </div>

      <% if (settings.organizationLogoPath) { %>
        <img
          class="results-overview-hero__logo"
          src="<%= settings.organizationLogoPath %>"
          alt="<%= settings.electionName %> logo"
        />
      <% } else { %>
        <div class="results-overview-hero__logo-fallback"><%= getInitials(settings.electionName) %></div>
      <% } %>
    </div>
  </div>

  <div class="results-kpi-grid">
    <article class="results-kpi-card">
      <span>Registered Voters</span>
      <strong><%= metrics.totalVoters.toLocaleString() %></strong>
      <small>Total eligible voters in the register</small>
    </article>

    <article class="results-kpi-card">
      <span>Votes Cast</span>
      <strong><%= metrics.votedCount.toLocaleString() %></strong>
      <small>Verified ballots recorded successfully</small>
    </article>

    <article class="results-kpi-card">
      <span>Turnout Rate</span>
      <strong><%= metrics.totalVoters ? formatPercent(turnoutRatio) : '0.0%' %></strong>
      <small>Overall participation across the election</small>
    </article>

    <article class="results-kpi-card">
      <span>Non-Voters</span>
      <strong><%= nonVoters.toLocaleString() %></strong>
      <small>Registered staff who did not submit a ballot</small>
    </article>
  </div>

  <div class="results-turnout-band">
    <div class="results-turnout-band__copy">
      <span class="eyebrow">Turnout Section</span>
      <h3>Participation snapshot</h3>
      <p>
        <strong><%= metrics.votedCount.toLocaleString() %></strong> out of
        <strong><%= metrics.totalVoters.toLocaleString() %></strong> registered voters submitted ballots.
      </p>
    </div>

    <div class="results-turnout-band__track">
      <div class="results-turnout-band__labels">
        <span>Voted</span>
        <strong><%= metrics.totalVoters ? formatPercent(turnoutRatio) : '0.0%' %></strong>
      </div>
      <div class="results-turnout-band__meter">
        <span class="results-turnout-band__fill" style="width: <%= turnoutWidth %>;"></span>
      </div>
      <div class="results-turnout-band__legend">
        <div>
          <strong><%= metrics.votedCount.toLocaleString() %></strong>
          <span>Votes cast</span>
        </div>
        <div>
          <strong><%= nonVoters.toLocaleString() %></strong>
          <span>Not voted</span>
        </div>
        <div>
          <strong><%= resultsStatusLabel %></strong>
          <span>Election status</span>
        </div>
      </div>
    </div>
  </div>
</section>
