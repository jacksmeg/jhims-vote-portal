<script>
  (() => {
    const countdownRoots = Array.from(document.querySelectorAll("[data-countdown-root]"));
    if (countdownRoots.length === 0) {
      return;
    }

    const renderUnit = (element, value, fallback = "00") => {
      if (element) {
        element.textContent = fallback === "--" ? fallback : String(value).padStart(2, "0");
      }
    };

    countdownRoots.forEach((countdownRoot) => {
      const targetTime = Number(countdownRoot.getAttribute("data-countdown-target") || "0");
      if (!Number.isFinite(targetTime) || targetTime <= 0) {
        return;
      }

      const dayEl = countdownRoot.querySelector("[data-countdown-days]");
      const hourEl = countdownRoot.querySelector("[data-countdown-hours]");
      const minuteEl = countdownRoot.querySelector("[data-countdown-minutes]");
      const secondEl = countdownRoot.querySelector("[data-countdown-seconds]");
      const titleEl = countdownRoot.querySelector("[data-countdown-title]");
      const copyEl = countdownRoot.querySelector("[data-countdown-copy]");
      const endedLabel = countdownRoot.getAttribute("data-countdown-ended-label") || "Voting has closed";
      const endedCopy = countdownRoot.getAttribute("data-countdown-ended-copy") || "";
      const shouldReloadAfterEnd =
        countdownRoot.getAttribute("data-countdown-end-reload") === "true";
      let timerId = null;
      let reloadQueued = false;

      const updateCountdown = () => {
        const remainingMs = Math.max(0, targetTime - Date.now());
        const totalSeconds = Math.floor(remainingMs / 1000);
        const days = Math.floor(totalSeconds / 86400);
        const hours = Math.floor((totalSeconds % 86400) / 3600);
        const minutes = Math.floor((totalSeconds % 3600) / 60);
        const seconds = totalSeconds % 60;

        renderUnit(dayEl, days);
        renderUnit(hourEl, hours);
        renderUnit(minuteEl, minutes);
        renderUnit(secondEl, seconds);

        if (remainingMs <= 0) {
          countdownRoot.classList.add("countdown-banner--ended");
          if (titleEl) {
            titleEl.textContent = endedLabel;
          }
          if (copyEl && endedCopy) {
            copyEl.textContent = endedCopy;
          }
          if (timerId) {
            window.clearInterval(timerId);
          }
          if (shouldReloadAfterEnd && !reloadQueued) {
            reloadQueued = true;
            window.setTimeout(() => {
              window.location.reload();
            }, 1200);
          }
        }
      };

      updateCountdown();
      timerId = window.setInterval(updateCountdown, 1000);
    });
  })();

  (() => {
    const copyButtons = Array.from(document.querySelectorAll("[data-copy-text]"));
    if (copyButtons.length === 0) {
      return;
    }

    const fallbackCopy = (text) => {
      const tempInput = document.createElement("textarea");
      tempInput.value = text;
      tempInput.setAttribute("readonly", "readonly");
      tempInput.style.position = "absolute";
      tempInput.style.left = "-9999px";
      document.body.appendChild(tempInput);
      tempInput.select();
      document.execCommand("copy");
      tempInput.remove();
    };

    copyButtons.forEach((button) => {
      const defaultLabel =
        button.getAttribute("data-copy-default-label") || button.textContent.trim() || "Copy";
      const successLabel =
        button.getAttribute("data-copy-success-label") || "Copied";

      button.addEventListener("click", async () => {
        const copyText = button.getAttribute("data-copy-text") || "";
        if (!copyText) {
          return;
        }

        try {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(copyText);
          } else {
            fallbackCopy(copyText);
          }

          button.textContent = successLabel;
          button.disabled = true;

          window.setTimeout(() => {
            button.textContent = defaultLabel;
            button.disabled = false;
          }, 1800);
        } catch (_error) {
          fallbackCopy(copyText);
          button.textContent = successLabel;
          button.disabled = true;

          window.setTimeout(() => {
            button.textContent = defaultLabel;
            button.disabled = false;
          }, 1800);
        }
      });
    });
  })();

  (() => {
    const toggles = Array.from(document.querySelectorAll("[data-disclosure-toggle]"));
    if (toggles.length === 0) {
      return;
    }

    const togglesByPanelId = new Map();
    const panels = Array.from(document.querySelectorAll("[data-disclosure-panel]"));

    const setToggleState = (toggle, isOpen) => {
      const openLabel = toggle.getAttribute("data-open-label") || "Hide Section";
      const closeLabel = toggle.getAttribute("data-close-label") || "Open Section";
      toggle.classList.toggle("is-active", isOpen);
      toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
      toggle.textContent = isOpen ? openLabel : closeLabel;
    };

    const syncPanelState = (panel, isOpen, { scrollIntoView = false } = {}) => {
      panel.hidden = !isOpen;
      panel.classList.toggle("is-open", isOpen);

      const linkedToggles = togglesByPanelId.get(panel.id) || [];
      linkedToggles.forEach((toggle) => {
        setToggleState(toggle, isOpen);
      });

      if (isOpen && scrollIntoView) {
        window.setTimeout(() => {
          panel.scrollIntoView({ behavior: "smooth", block: "start" });
        }, 40);
      }
    };

    toggles.forEach((toggle) => {
      const panelId = toggle.getAttribute("data-disclosure-target") || "";
      if (!panelId) {
        return;
      }

      const panel = document.getElementById(panelId);
      if (!panel) {
        return;
      }

      const linkedToggles = togglesByPanelId.get(panelId) || [];
      linkedToggles.push(toggle);
      togglesByPanelId.set(panelId, linkedToggles);
      setToggleState(toggle, !panel.hidden);

      toggle.addEventListener("click", () => {
        const shouldOpen = panel.hidden;
        syncPanelState(panel, shouldOpen, { scrollIntoView: shouldOpen });
      });
    });

    panels.forEach((panel) => {
      syncPanelState(panel, false);
    });

    const openPanelFromHash = () => {
      const hash = window.location.hash ? window.location.hash.slice(1) : "";
      if (!hash) {
        return;
      }

      const target = document.getElementById(hash);
      if (!target) {
        return;
      }

      const panel = target.matches("[data-disclosure-panel]")
        ? target
        : target.closest("[data-disclosure-panel]");

      if (!panel) {
        return;
      }

      syncPanelState(panel, true, { scrollIntoView: true });
    };

    openPanelFromHash();
    window.addEventListener("hashchange", openPanelFromHash);
  })();
</script>
