<%- include("partials/public-shell-start", { pageTitle }) %>

<section class="panel panel-light stack-lg">
  <div class="section-heading">
    <div>
      <span class="eyebrow">Nomination Form</span>
      <h2><%= editableNomination ? 'Update and resubmit your nomination' : 'Submit your nomination application' %></h2>
    </div>
    <p>
      <% if (editableNomination) { %>
        The committee requested correction on this nomination. Update the details below and resubmit.
      <% } else { %>
        Fill every field carefully before you submit. After submission, you will receive an application number for status tracking.
      <% } %>
    </p>
  </div>

  <% if (formLocked) { %>
    <p class="note-block otp-note--warning">
      <strong>Submission locked for now:</strong>
      Nominations will open on <%= formatDateTime(settings.nominationOpensAt) %>. You can review the form below and use
      <strong>Check Status</strong> for any existing application, but new submission starts only when the countdown finishes.
    </p>
  <% } %>

  <% if (editableNomination && editableNomination.adminNotes) { %>
    <p class="note-block"><strong>Committee Note:</strong> <%= editableNomination.adminNotes %></p>
  <% } %>

  <div class="nomination-layout">
    <form class="stack-md" action="/nomination/form" method="post" enctype="multipart/form-data">
      <% if (editableNomination) { %>
        <input type="hidden" name="nominationId" value="<%= editableNomination.id %>" />
      <% } %>

      <fieldset class="nomination-form-fieldset stack-md" <%= formLocked ? 'disabled' : '' %>>
        <div class="form-grid">
          <label class="field">
            <span>Full Name</span>
            <input
              name="fullName"
              value="<%= editableNomination ? editableNomination.fullName : '' %>"
              required
            />
          </label>

          <label class="field">
            <span>Department</span>
            <input
              name="department"
              value="<%= editableNomination ? editableNomination.department : '' %>"
              required
            />
          </label>
        </div>

        <div class="form-grid">
          <label class="field">
            <span>Staff ID</span>
            <input
              name="staffId"
              value="<%= editableNomination ? editableNomination.staffId : '' %>"
              placeholder="STF0234"
              required
            />
          </label>

          <label class="field">
            <span>Phone Number</span>
            <input
              name="phoneNumber"
              value="<%= editableNomination ? editableNomination.phoneNumber : '' %>"
              placeholder="0240000000"
              required
            />
          </label>
        </div>

        <div class="form-grid">
          <label class="field">
            <span>Application Number</span>
            <input
              value="<%= editableNomination ? editableNomination.applicationNumber : 'Assigned automatically after submission' %>"
              disabled
            />
          </label>

          <label class="field">
            <span>Position Applying For</span>
            <select name="positionId" required>
              <option value="">Select a position</option>
              <% positions.forEach((position) => { %>
                <option
                  value="<%= position.id %>"
                  <%= (editableNomination ? editableNomination.positionId : '') === position.id ? 'selected' : '' %>
                >
                  <%= position.name %>
                </option>
              <% }) %>
            </select>
          </label>
        </div>

        <label class="field">
          <span>Candidate Photo</span>
          <input name="photo" type="file" accept="image/*" <%= editableNomination ? '' : 'required' %> />
        </label>

        <label class="field">
          <span>Short Profile / Bio</span>
          <textarea name="bio" rows="4" required><%= editableNomination ? editableNomination.bio : '' %></textarea>
        </label>

        <label class="field">
          <span>Manifesto / Message</span>
          <textarea name="manifesto" rows="5" required><%= editableNomination ? editableNomination.manifesto : '' %></textarea>
        </label>

        <div class="form-grid">
          <label class="field">
            <span>Proposer Name</span>
            <input name="proposerName" value="<%= editableNomination ? editableNomination.proposerName : '' %>" required />
          </label>

          <label class="field">
            <span>Seconder Name</span>
            <input name="seconderName" value="<%= editableNomination ? editableNomination.seconderName : '' %>" required />
          </label>
        </div>

        <label class="field-checkbox">
          <input type="checkbox" name="declarationAccepted" <%= editableNomination?.declarationAccepted ? 'checked' : '' %> required />
          <span>I confirm that all details in this nomination form are accurate and submitted by me.</span>
        </label>
      </fieldset>

      <div class="button-row">
        <button class="button" type="submit" <%= formLocked ? 'disabled' : '' %>>
          <%= formLocked
            ? 'Submission Opens Automatically'
            : editableNomination
              ? 'Resubmit Nomination'
              : 'Submit Nomination' %>
        </button>
        <a class="button button-ghost" href="/nomination/status/login">Check Status</a>
        <a class="button button-ghost" href="#nomination-guide-inline">How to Apply</a>
      </div>
    </form>

    <aside class="panel panel-light nomination-sidebar-card">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Submission Guide</span>
          <h3>What happens next</h3>
        </div>
      </div>

      <div class="stack-sm">
        <div class="mini-card">
          <strong>Application Number</strong>
          <span><%= editableNomination ? editableNomination.applicationNumber : 'Issued after submission' %></span>
        </div>

        <div class="mini-card">
          <strong>Status</strong>
          <span><%= editableNomination ? editableNomination.statusMeta.label : formLocked ? 'Waiting for nomination opening time' : 'Ready for first submission' %></span>
        </div>

        <% if (editableNomination) { %>
          <div class="mini-card">
            <strong>Last Submitted</strong>
            <span><%= formatDateTime(editableNomination.submittedAt) %></span>
          </div>
        <% } else if (formLocked) { %>
          <div class="mini-card">
            <strong>Opens At</strong>
            <span><%= formatDateTime(settings.nominationOpensAt) %></span>
          </div>
        <% } else { %>
          <div class="mini-card">
            <strong>Important</strong>
            <span>Save the application number shown after submission because you will need it to check your status later.</span>
          </div>
        <% } %>

        <div class="mini-card">
          <strong>Need help?</strong>
          <span><a href="#nomination-guide-inline">Read the nomination guide before you submit.</a></span>
        </div>
      </div>
    </aside>
  </div>
</section>

<section class="panel panel-light stack-lg" id="nomination-guide-inline">
  <div class="section-heading">
    <div>
      <span class="eyebrow">How To Apply</span>
      <h3>Step-by-step nomination guide for applicants</h3>
    </div>
    <a class="button button-ghost button-small" href="/nomination/form">Back to Form</a>
  </div>

  <ol class="flow-list">
    <li>Open the nomination form during the nomination window.</li>
    <li>If the opening time has not reached yet, review the form and wait for the countdown to unlock submission.</li>
    <li>Fill in your full name, department, staff ID, phone number, and the position you want to contest.</li>
    <li>Upload your photo and complete your short profile, manifesto, proposer name, and seconder name.</li>
    <li>Tick the declaration checkbox and submit the nomination form once submission is open.</li>
    <li>After successful submission, save the application number shown by the system.</li>
    <li>Use that application number later to check your status, download your filled form, or continue any correction requested by the committee.</li>
  </ol>

  <div class="feature-grid guide-feature-grid">
    <article class="feature-card">
      <h4>Timing matters</h4>
      <p>Nominations close automatically when voting starts, so submit before the election opens.</p>
    </article>
    <article class="feature-card">
      <h4>Save your number</h4>
      <p>Your application number is the only number you need for status checking and future follow-up.</p>
    </article>
    <article class="feature-card">
      <h4>Committee review</h4>
      <p>Every nomination is reviewed before it can be approved and published as a candidate.</p>
    </article>
  </div>
</section>

<%- include("partials/public-shell-end") %>
