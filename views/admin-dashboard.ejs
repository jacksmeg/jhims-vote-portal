<%- include("partials/admin-shell-start", {
  pageTitle,
  pageHeading: "Admin Dashboard",
  pageIntro: "Live turnout, election schedule, and committee actions in one control center.",
  currentSection: "dashboard"
}) %>

<%
  const turnoutStrokeCircumference = 276.46;
  const turnoutStroke = (turnoutRate * turnoutStrokeCircumference).toFixed(2);
  const scheduleStateLabel = electionState.isOpen
    ? 'Open'
    : electionState.isScheduled
      ? 'Scheduled'
      : electionState.isClosed
        ? 'Closed'
        : 'Setup';
  const scheduleMetaLabel = electionState.isOpen
    ? 'Live voting in progress'
    : electionState.isScheduled
      ? 'Auto-open enabled'
      : electionState.isClosed
        ? 'Ballot locked and finalized'
        : 'Awaiting setup completion';
  const readyPositions = positionReadiness.filter((position) => position.candidateCount > 0);
  const positionsNeedingCandidates = positionReadiness.filter((position) => position.candidateCount === 0);
  const readinessRatio = positionReadiness.length ? readyPositions.length / positionReadiness.length : 0;
  const readinessPercent = formatPercent(readinessRatio);
  const readinessMessage = positionReadiness.length === 0
    ? 'Create positions first before the ballot can be prepared.'
    : positionsNeedingCandidates.length === 0
      ? 'Every listed position already has at least one candidate.'
      : `${positionsNeedingCandidates.length} position${positionsNeedingCandidates.length === 1 ? '' : 's'} still need candidate setup before the ballot is fully ready.`;
  const recentArchives = archives.slice(0, 2);
  const leadingCandidate = topCandidates[0] || null;
  const clearLeadPositions = resultsPreview.filter((position) =>
    position.totalVotes > 0 &&
    position.marginLabel !== 'Tie' &&
    position.winnerLabel !== 'No votes recorded' &&
    position.winnerLabel !== 'No candidates added'
  );
  const closeRaceCount = resultsPreview.filter((position) =>
    position.totalVotes > 0 &&
    position.marginLabel !== 'Tie' &&
    position.marginVotes > 0 &&
    position.marginVotes <= 5
  ).length;
  const declaredPositionCount = electionState.isClosed ? clearLeadPositions.length : 0;
  const projectedWinnersCount = electionState.isClosed ? declaredPositionCount : clearLeadPositions.length;
  const closesAtDate = settings.closesAt ? new Date(settings.closesAt) : null;
  const countingDate = closesAtDate ? new Date(closesAtDate.getTime() + 2 * 60 * 60 * 1000) : null;
  const declarationDate = closesAtDate ? new Date(closesAtDate.getTime() + Math.round(2.5 * 60 * 60 * 1000)) : null;
  const timeLeftMs = closesAtDate ? closesAtDate.getTime() - Date.now() : null;
  const timeLeftLabel =
    electionState.isOpen && timeLeftMs && timeLeftMs > 0
      ? `In ${Math.floor(timeLeftMs / 3600000)}h ${Math.floor((timeLeftMs % 3600000) / 60000)}m`
      : electionState.isClosed
        ? 'Closed'
        : electionState.isScheduled
          ? 'Scheduled'
          : 'Upcoming';
  const scheduleMoments = [
    {
      label: 'Voting Opens',
      value: settings.opensAt ? formatDateTime(settings.opensAt) : 'Not scheduled yet',
      badge: electionState.isOpen || electionState.isClosed ? 'Open' : electionState.isScheduled ? 'Scheduled' : 'Pending',
      toneClass: electionState.isOpen || electionState.isClosed ? 'is-green' : electionState.isScheduled ? 'is-blue' : 'is-slate',
    },
    {
      label: 'Voting Closes',
      value: settings.closesAt ? formatDateTime(settings.closesAt) : 'Not scheduled yet',
      badge: timeLeftLabel,
      toneClass: electionState.isOpen ? 'is-amber' : electionState.isClosed ? 'is-slate' : 'is-blue',
    },
    {
      label: 'Counting & Verification',
      value: countingDate ? formatDateTime(countingDate.toISOString()) : 'After close of polls',
      badge: electionState.isClosed ? 'Active' : 'Upcoming',
      toneClass: electionState.isClosed ? 'is-green' : 'is-slate',
    },
    {
      label: 'Results Announcement',
      value: declarationDate ? formatDateTime(declarationDate.toISOString()) : 'Committee controlled',
      badge: electionState.isClosed ? 'Ready' : 'Upcoming',
      toneClass: electionState.isClosed ? 'is-blue' : 'is-slate',
    }
  ];
  const lineChartTicks = Array.from({ length: 5 }, (_, index) => {
    const ratio = 1 - index / 4;
    return Math.round((timelineChart.maxValue * ratio) / 100) * 100;
  });
%>

<section class="control-metrics-grid">
  <article class="control-metric-card control-metric-card--emerald">
    <span class="control-metric-card__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false">
        <path d="M16 11a4 4 0 1 0-3.999-4A4 4 0 0 0 16 11Zm-8 2a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm0 2c-2.33 0-7 1.17-7 3.5V20h9v-1.5c0-.97.4-1.86 1.12-2.59A11.66 11.66 0 0 0 8 15Zm8 0c-2.67 0-8 1.34-8 4v1h16v-1c0-2.66-5.33-4-8-4Z" fill="currentColor"/>
      </svg>
    </span>
    <div class="control-metric-card__body">
      <span>Registered Voters</span>
      <strong><%= metrics.totalVoters.toLocaleString() %></strong>
      <small>Total eligible voters</small>
    </div>
  </article>

  <article class="control-metric-card control-metric-card--blue">
    <span class="control-metric-card__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false">
        <path d="m10 16.2-3.5-3.5 1.4-1.4 2.1 2.1 5-5L16.4 9l-6.4 7.2ZM5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z" fill="currentColor"/>
      </svg>
    </span>
    <div class="control-metric-card__body">
      <span>Voted</span>
      <strong><%= metrics.votedCount.toLocaleString() %></strong>
      <small>Total votes cast</small>
    </div>
  </article>

  <article class="control-metric-card control-metric-card--teal">
    <span class="control-metric-card__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false">
        <path d="M12 2a10 10 0 1 0 10 10H12V2Zm2 2.3V12h7.7A8 8 0 0 0 14 4.3Z" fill="currentColor"/>
      </svg>
    </span>
    <div class="control-metric-card__body">
      <span>Turnout</span>
      <strong><%= formatPercent(turnoutRate) %></strong>
      <small><%= notVotedCount.toLocaleString() %> voters pending</small>
    </div>
  </article>

  <article class="control-metric-card control-metric-card--amber">
    <span class="control-metric-card__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false">
        <path d="M7 2h2v2h6V2h2v2h2a2 2 0 0 1 2 2v12a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6a2 2 0 0 1 2-2h2V2Zm12 8H5v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-8Z" fill="currentColor"/>
      </svg>
    </span>
    <div class="control-metric-card__body">
      <span>Active Positions</span>
      <strong><%= metrics.totalPositions.toLocaleString() %></strong>
      <small><%= metrics.totalCandidates.toLocaleString() %> active candidates</small>
    </div>
  </article>
</section>

<section class="control-stage-grid">
  <article class="control-card control-card--schedule">
    <div class="control-card__header">
      <div>
        <h2>Election Schedule</h2>
        <p>All times are in GMT and follow the active election window.</p>
      </div>
    </div>

    <div class="control-schedule-list">
      <% scheduleMoments.forEach((entry, index) => { %>
        <div class="control-schedule-item">
          <div class="control-schedule-item__rail">
            <span class="control-schedule-item__dot <%= index === 0 ? 'is-open' : index === 1 ? 'is-blue' : 'is-slate' %>"></span>
            <% if (index < scheduleMoments.length - 1) { %>
              <span class="control-schedule-item__line"></span>
            <% } %>
          </div>
          <div class="control-schedule-item__body">
            <strong><%= entry.label %></strong>
            <span><%= entry.value %></span>
          </div>
          <span class="control-schedule-badge <%= entry.toneClass %>"><%= entry.badge %></span>
        </div>
      <% }) %>
    </div>

    <div class="control-schedule-note">
      <span aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 3a9 9 0 1 0 9 9 9.01 9.01 0 0 0-9-9Zm1 9.59 3.3 3.3-1.41 1.41L11 13V7h2Z" fill="currentColor"/>
        </svg>
      </span>
      <p><%= electionState.message %></p>
    </div>
  </article>

  <article class="control-card control-card--turnout">
    <div class="control-card__header">
      <div>
        <h2>Live Turnout</h2>
        <p>Updated from the current ballots recorded in the system.</p>
      </div>
      <a class="control-inline-link" href="/admin/results">View details</a>
    </div>

    <div class="control-turnout-layout">
      <div
        class="turnout-donut control-turnout-donut"
        style="--turnout-circumference: <%= turnoutStrokeCircumference %>; --turnout-progress: <%= turnoutStroke %>;"
      >
        <svg viewBox="0 0 120 120" aria-hidden="true">
          <circle cx="60" cy="60" r="44"></circle>
          <circle class="turnout-donut__progress" cx="60" cy="60" r="44"></circle>
        </svg>
        <div class="turnout-donut__label">
          <strong><%= formatPercent(turnoutRate) %></strong>
          <span>Turnout</span>
        </div>
      </div>

      <div class="control-turnout-legend">
        <div>
          <span class="control-turnout-legend__dot is-voted"></span>
          <span>Voted</span>
          <strong><%= metrics.votedCount.toLocaleString() %> (<%= formatPercent(turnoutRate) %>)</strong>
        </div>
        <div>
          <span class="control-turnout-legend__dot is-pending"></span>
          <span>Not Voted</span>
          <strong><%= notVotedCount.toLocaleString() %> (<%= formatPercent(metrics.totalVoters ? notVotedCount / metrics.totalVoters : 0) %>)</strong>
        </div>
      </div>
    </div>

    <div class="control-turnout-footer">
      <span class="control-turnout-footer__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M16 11a4 4 0 1 0-3.999-4A4 4 0 0 0 16 11Zm-8 2a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm0 2c-2.33 0-7 1.17-7 3.5V20h9v-1.5c0-.97.4-1.86 1.12-2.59A11.66 11.66 0 0 0 8 15Zm8 0c-2.67 0-8 1.34-8 4v1h16v-1c0-2.66-5.33-4-8-4Z" fill="currentColor"/>
        </svg>
      </span>
      <p><strong><%= metrics.votedCount.toLocaleString() %></strong> of <strong><%= metrics.totalVoters.toLocaleString() %></strong> voters have voted.</p>
    </div>
  </article>

  <article class="control-card control-card--trend">
    <div class="control-card__header">
      <div>
        <h2>Votes Over Time</h2>
        <p>Ballot submissions across the active voting window.</p>
      </div>
      <span class="control-select-pill">Today</span>
    </div>

    <div class="control-chart-shell">
      <div class="control-chart-yaxis">
        <% lineChartTicks.forEach((tick) => { %>
          <span><%= tick.toLocaleString() %></span>
        <% }) %>
      </div>

      <div class="control-chart-plot">
        <div class="control-chart-gridlines" aria-hidden="true">
          <% lineChartTicks.forEach(() => { %>
            <span></span>
          <% }) %>
        </div>
        <div class="dashboard-line-chart control-line-chart">
          <svg viewBox="0 0 <%= timelineChart.width %> <%= timelineChart.height %>" aria-hidden="true">
            <defs>
              <linearGradient id="controlTrendFill" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="rgba(14, 187, 168, 0.32)"></stop>
                <stop offset="100%" stop-color="rgba(14, 187, 168, 0)"></stop>
              </linearGradient>
            </defs>
            <polygon points="<%= timelineChart.areaPoints %>" fill="url(#controlTrendFill)"></polygon>
            <polyline points="<%= timelineChart.points %>" fill="none"></polyline>
          </svg>

          <div class="dashboard-line-chart__axis control-line-chart__axis">
            <% timelineSeries.forEach((point) => { %>
              <span><%= point.label %></span>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </article>
</section>

<section class="control-bottom-grid">
  <article class="control-card control-card--candidates">
    <div class="control-card__header">
      <div>
        <h2>Top Candidates</h2>
        <p>Live ranking by vote count.</p>
      </div>
      <a class="control-inline-link" href="/admin/results">View all</a>
    </div>

    <div class="control-candidate-list">
      <% if (topCandidates.length === 0) { %>
        <div class="empty-state">Candidates will appear here after setup.</div>
      <% } else { %>
        <% topCandidates.slice(0, 3).forEach((candidate, index) => { %>
          <div class="control-candidate-row">
            <span class="control-candidate-rank"><%= index + 1 %></span>

            <% if (candidate.photoPath) { %>
              <img class="control-candidate-avatar" src="<%= candidate.photoPath %>" alt="<%= candidate.name %>" />
            <% } else { %>
              <span class="control-candidate-avatar control-candidate-avatar--fallback"><%= getInitials(candidate.name) %></span>
            <% } %>

            <div class="control-candidate-copy">
              <strong><%= candidate.name %></strong>
              <span><%= candidate.voteCount.toLocaleString() %> votes</span>
              <div class="control-candidate-meter">
                <span style="width: <%= candidate.shareRatio ? `${Math.max(candidate.shareRatio * 100, 14)}%` : '0%' %>;"></span>
              </div>
            </div>

            <div class="control-candidate-share"><%= formatPercent(candidate.shareRatio || 0) %></div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </article>

  <article class="control-card control-card--activity">
    <div class="control-card__header">
      <div>
        <h2>Recent Activity</h2>
        <p>Latest committee and voter actions.</p>
      </div>
      <a class="control-inline-link" href="/admin/audit">View all</a>
    </div>

    <div class="control-activity-list">
      <% if (activityFeed.length === 0) { %>
        <div class="empty-state">No activity has been recorded yet.</div>
      <% } else { %>
        <% activityFeed.forEach((entry) => { %>
          <div class="control-activity-row">
            <span class="control-activity-dot <%= entry.accentClass %>"></span>
            <div class="control-activity-copy">
              <strong><%= entry.actionLabel %></strong>
              <span><%= entry.detailLabel || entry.actorIdentifier %></span>
            </div>
            <small><%= entry.timeAgo %></small>
          </div>
        <% }) %>
      <% } %>
    </div>
  </article>

  <div class="control-side-stack">
    <article class="control-card control-card--quick-actions">
      <div class="control-card__header">
        <div>
          <h2>Quick Actions</h2>
          <p>Open the core election tools faster.</p>
        </div>
      </div>

      <div class="control-action-grid">
        <a class="control-action-tile" href="/admin/voters">
          <span class="control-action-tile__icon is-green" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M16 11a4 4 0 1 0-3.999-4A4 4 0 0 0 16 11Zm-8 2a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm0 2c-2.33 0-7 1.17-7 3.5V20h9v-1.5c0-.97.4-1.86 1.12-2.59A11.66 11.66 0 0 0 8 15Zm8 0c-2.67 0-8 1.34-8 4v1h16v-1c0-2.66-5.33-4-8-4Z" fill="currentColor"/>
            </svg>
          </span>
          <strong>Add Voter</strong>
        </a>

        <a class="control-action-tile" href="/admin/setup#candidate-management">
          <span class="control-action-tile__icon is-blue" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M5 4h14a1 1 0 0 1 1 1v3H4V5a1 1 0 0 1 1-1Zm-1 6h16v9a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-9Zm3 2v2h2v-2H7Zm4 0v2h6v-2h-6Zm-4 4v2h2v-2H7Zm4 0v2h4v-2h-4Z" fill="currentColor"/>
            </svg>
          </span>
          <strong>Add Candidate</strong>
        </a>

        <a class="control-action-tile" href="/admin/positions">
          <span class="control-action-tile__icon is-violet" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h10v2H4v-2Z" fill="currentColor"/>
            </svg>
          </span>
          <strong>Create Position</strong>
        </a>

        <a class="control-action-tile" href="/admin/results">
          <span class="control-action-tile__icon is-teal" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M5 19h14v2H3V5h2v14Zm3-8h2v6H8v-6Zm4-4h2v10h-2V7Zm4 2h2v8h-2V9Z" fill="currentColor"/>
            </svg>
          </span>
          <strong>View Reports</strong>
        </a>

        <a class="control-action-tile" href="/admin/settings#security">
          <span class="control-action-tile__icon is-amber" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M3 5h18v10H8l-5 4V5Zm4 3v2h10V8H7Zm0 4v2h6v-2H7Z" fill="currentColor"/>
            </svg>
          </span>
          <strong>Send SMS</strong>
        </a>
      </div>
    </article>

    <article class="control-card control-card--snapshot">
      <div class="control-card__header">
        <div>
          <h2>Results Snapshot</h2>
          <p>High-level outcome view from the live tallies.</p>
        </div>
        <a class="control-inline-link" href="/admin/results">View results</a>
      </div>

      <div class="control-snapshot-grid">
        <article class="control-snapshot-card is-mint">
          <span>Projected</span>
          <strong><%= projectedWinnersCount %></strong>
          <small>Positions with a clear leader</small>
        </article>

        <article class="control-snapshot-card is-blue">
          <span>Leading</span>
          <% if (leadingCandidate) { %>
            <strong><%= leadingCandidate.name %></strong>
            <small><%= formatPercent(leadingCandidate.shareRatio || 0) %></small>
          <% } else { %>
            <strong>None yet</strong>
            <small>Awaiting votes</small>
          <% } %>
        </article>

        <article class="control-snapshot-card is-amber">
          <span>Close Race</span>
          <strong><%= closeRaceCount %></strong>
          <small>Positions under 5-vote margin</small>
        </article>

        <article class="control-snapshot-card is-violet">
          <span>Declared</span>
          <strong><%= declaredPositionCount %></strong>
          <small>Final only after close</small>
        </article>
      </div>
    </article>
  </div>
</section>

<section class="panel panel-light stack-lg dashboard-workspace-panel" id="workspace-settings">
  <div class="section-heading">
    <div>
      <span class="eyebrow">Workspace Settings</span>
      <h2>Advanced tools without the clutter</h2>
    </div>
    <p>These controls stay available, but they are tucked away so the dashboard remains easier to scan.</p>
  </div>

  <div class="dashboard-workspace-glance">
    <div class="mini-metrics-grid">
      <div>
        <strong><%= readyPositions.length %></strong>
        <span>Ready positions</span>
      </div>
      <div>
        <strong><%= positionsNeedingCandidates.length %></strong>
        <span>Need candidates</span>
      </div>
      <div>
        <strong><%= recentArchives.length %></strong>
        <span>Recent archives</span>
      </div>
    </div>

    <div class="note-block">
      <strong>Readiness:</strong> <%= readinessMessage %>
    </div>
  </div>

  <div class="dashboard-disclosure-stack">
    <details class="dashboard-disclosure" <%= electionState.canEditSetup ? 'open' : '' %>>
      <summary class="dashboard-disclosure__summary">
        <div>
          <strong>Election control</strong>
          <span>Set the voting window, open or close voting, and create backups.</span>
        </div>
      </summary>

      <div class="dashboard-disclosure__content">
        <article class="dashboard-subpanel stack-md" id="election-control-panel">
          <div class="section-heading section-heading--tight">
            <div>
              <span class="eyebrow">Election Control</span>
              <h2>Voting window and controls</h2>
            </div>
            <p>These settings stay editable only while the election is in setup, and a ready election can open automatically at the scheduled time.</p>
          </div>

    <form class="stack-md" action="/admin/settings" method="post">
      <label class="field">
        <span>Election Name</span>
        <input
          name="electionName"
          value="<%= settings.electionName %>"
          <%= electionState.canEditSetup ? '' : 'disabled' %>
          required
        />
      </label>

      <div class="form-grid">
        <label class="field">
          <span>Voting Opens</span>
          <input
            name="opensAt"
            type="datetime-local"
            value="<%= settings.opensAt %>"
            <%= electionState.canEditSetup ? '' : 'disabled' %>
            required
          />
        </label>

        <label class="field">
          <span>Voting Closes</span>
          <input
            name="closesAt"
            type="datetime-local"
            value="<%= settings.closesAt %>"
            <%= electionState.canEditSetup ? '' : 'disabled' %>
            required
          />
        </label>
      </div>

      <button class="button" type="submit" <%= electionState.canEditSetup ? '' : 'disabled' %>>
        Save Settings
      </button>
    </form>

    <div class="button-stack">
      <form action="/admin/election/open" method="post">
        <button class="button" type="submit" <%= electionState.canEditSetup ? '' : 'disabled' %>>
          Open Voting Now
        </button>
      </form>

      <form action="/admin/election/close" method="post">
        <button class="button button-danger" type="submit" <%= settings.phase === 'open' ? '' : 'disabled' %>>
          Close Voting
        </button>
      </form>

      <form action="/admin/backup" method="post">
        <button class="button button-ghost" type="submit">Create Database Backup</button>
      </form>
    </div>

    <div class="note-block">
      <strong>Status:</strong> <%= electionState.message %>
    </div>
        </article>
      </div>
    </details>

    <details class="dashboard-disclosure">
      <summary class="dashboard-disclosure__summary">
        <div>
          <strong>Branding and declaration</strong>
          <span>Manage the portal logo, report title, and signature settings.</span>
        </div>
      </summary>

      <div class="dashboard-disclosure__content dashboard-disclosure__content--grid">
        <article class="dashboard-subpanel stack-md" id="branding-panel">
          <div class="section-heading section-heading--tight">
            <div>
              <span class="eyebrow">Branding</span>
              <h2>Organization logo</h2>
            </div>
            <p>Upload once and reuse it across both admin and voter pages.</p>
          </div>

    <div class="brand-upload-panel">
      <div class="brand-upload-panel__preview">
        <% if (settings.organizationLogoPath) { %>
          <img
            class="brand-upload-panel__image"
            src="<%= settings.organizationLogoPath %>"
            alt="<%= settings.electionName %> logo"
          />
        <% } else { %>
          <div class="brand-upload-panel__fallback">No logo uploaded yet</div>
        <% } %>
      </div>

      <form class="stack-md brand-upload-panel__form" action="/admin/logo" method="post" enctype="multipart/form-data">
        <label class="field">
          <span>Upload Organization Logo</span>
          <input name="logo" type="file" accept="image/*" required />
        </label>

        <button class="button" type="submit">Save Logo</button>
      </form>
    </div>
        </article>

        <article class="dashboard-subpanel stack-md" id="declaration-panel">
          <div class="section-heading section-heading--tight">
            <div>
              <span class="eyebrow">Declaration Settings</span>
              <h2>Official sign-off details</h2>
            </div>
            <p>Set the report title, committee name, office holders, and upload the official signatures.</p>
          </div>

    <div class="declaration-settings-layout">
      <form
        class="stack-md declaration-settings-layout__form"
        action="/admin/declaration"
        method="post"
        enctype="multipart/form-data"
      >
        <div class="form-grid">
          <label class="field">
            <span>Declaration Title</span>
            <input
              name="declarationTitle"
              value="<%= settings.declarationTitle %>"
              placeholder="Official Declaration Block"
              required
            />
          </label>

          <label class="field">
            <span>Committee Name</span>
            <input
              name="committeeName"
              value="<%= settings.committeeName %>"
              placeholder="Election Committee"
              required
            />
          </label>
        </div>

        <div class="form-grid">
          <label class="field">
            <span>Chairman Name</span>
            <input
              name="chairmanName"
              value="<%= settings.chairmanName %>"
              placeholder="Chairman Name"
            />
          </label>

          <label class="field">
            <span>Secretary Name</span>
            <input
              name="secretaryName"
              value="<%= settings.secretaryName %>"
              placeholder="Secretary Name"
            />
          </label>
        </div>

        <div class="form-grid">
          <label class="field">
            <span>Chairman Signature</span>
            <input name="chairmanSignature" type="file" accept="image/*" />
          </label>

          <label class="field">
            <span>Secretary Signature</span>
            <input name="secretarySignature" type="file" accept="image/*" />
          </label>
        </div>

        <button class="button" type="submit">Save Declaration Settings</button>
      </form>

      <div class="signature-preview-grid">
        <article class="signature-preview-card">
          <span class="eyebrow">Chairman Preview</span>
          <div class="signature-preview-card__canvas">
            <% if (settings.chairmanSignaturePath) { %>
              <img
                class="signature-preview-card__image"
                src="<%= settings.chairmanSignaturePath %>"
                alt="<%= settings.chairmanName || 'Chairman' %> signature"
              />
            <% } else { %>
              <div class="brand-upload-panel__fallback">No chairman signature uploaded yet</div>
            <% } %>
          </div>
          <strong><%= settings.chairmanName || 'Chairman' %></strong>
        </article>

        <article class="signature-preview-card">
          <span class="eyebrow">Secretary Preview</span>
          <div class="signature-preview-card__canvas">
            <% if (settings.secretarySignaturePath) { %>
              <img
                class="signature-preview-card__image"
                src="<%= settings.secretarySignaturePath %>"
                alt="<%= settings.secretaryName || 'Secretary' %> signature"
              />
            <% } else { %>
              <div class="brand-upload-panel__fallback">No secretary signature uploaded yet</div>
            <% } %>
          </div>
          <strong><%= settings.secretaryName || 'Secretary' %></strong>
        </article>
      </div>
    </div>
        </article>
      </div>
    </details>

    <details class="dashboard-disclosure" <%= adminTwoFactorState.enabled || pendingAdminTwoFactorSetup ? 'open' : '' %>>
      <summary class="dashboard-disclosure__summary">
        <div>
          <strong>Security and appearance</strong>
          <span>Protect the admin account and control the portal theme.</span>
        </div>
      </summary>

      <div class="dashboard-disclosure__content dashboard-disclosure__content--grid">
        <article class="dashboard-subpanel stack-md" id="security-panel">
          <div class="section-heading section-heading--tight">
            <div>
              <span class="eyebrow">Admin Security</span>
              <h2>Two-factor authentication</h2>
            </div>
            <p>Protect administrator access with an authenticator app like Google Authenticator or Microsoft Authenticator.</p>
          </div>

      <% if (adminTwoFactorState.enabled) { %>
        <div class="note-block">
          <strong>Status:</strong> Two-factor authentication is currently enabled for the admin account.
        </div>

        <form class="stack-md" action="/admin/2fa/disable" method="post">
          <label class="field">
            <span>Current Authenticator Code</span>
            <input
              name="verificationCode"
              inputmode="numeric"
              autocomplete="one-time-code"
              placeholder="123456"
              maxlength="6"
              required
            />
          </label>

          <button class="button button-danger" type="submit">Disable 2FA</button>
        </form>
      <% } else if (pendingAdminTwoFactorSetup) { %>
        <div class="stack-md">
          <div class="note-block">
            <strong>Step 1:</strong> Scan this QR code with your authenticator app.
          </div>

          <div class="two-factor-setup-grid">
            <article class="two-factor-qr-card">
              <% if (pendingAdminTwoFactorSetup.qrCodeDataUrl) { %>
                <img
                  class="two-factor-qr-card__image"
                  src="<%= pendingAdminTwoFactorSetup.qrCodeDataUrl %>"
                  alt="QR code for admin two-factor authenticator setup"
                />
              <% } else { %>
                <div class="brand-upload-panel__fallback">QR code preview unavailable right now</div>
              <% } %>
              <strong>Scan with Google Authenticator or Microsoft Authenticator</strong>
            </article>

            <div class="mini-card stack-sm">
              <div class="info-row"><span>Issuer</span><strong><%= pendingAdminTwoFactorSetup.issuer %></strong></div>
              <div class="info-row"><span>Account</span><strong><%= pendingAdminTwoFactorSetup.accountName %></strong></div>
              <div class="info-row"><span>Setup Key</span><strong><%= pendingAdminTwoFactorSetup.formattedSecret %></strong></div>
            </div>
          </div>

          <label class="field">
            <span>Manual Setup Link (Optional Backup)</span>
            <textarea rows="3" readonly><%- pendingAdminTwoFactorSetup.otpauthUri %></textarea>
          </label>

          <form class="stack-md" action="/admin/2fa/enable" method="post">
            <label class="field">
              <span>Step 2: Enter the 6-digit code from your app</span>
              <input
                name="verificationCode"
                inputmode="numeric"
                autocomplete="one-time-code"
                placeholder="123456"
                maxlength="6"
                required
              />
            </label>

            <div class="button-row">
              <button class="button" type="submit">Activate 2FA</button>
            </div>
          </form>

          <form action="/admin/2fa/cancel-setup" method="post">
            <button class="button button-ghost button-small" type="submit">Cancel Setup</button>
          </form>
        </div>
      <% } else { %>
        <div class="note-block">
          <strong>Status:</strong> Two-factor authentication is currently turned off for the admin account.
        </div>

        <form action="/admin/2fa/setup" method="post">
          <button class="button" type="submit">Start 2FA Setup</button>
        </form>
      <% } %>
        </article>

        <article class="dashboard-subpanel stack-md">
          <div class="section-heading section-heading--tight">
            <div>
              <span class="eyebrow">Software Theme</span>
              <h2>Portal appearance</h2>
            </div>
            <p>The selected theme applies to both voter and admin pages.</p>
          </div>

      <form class="stack-md" action="/admin/theme" method="post">
        <div class="theme-card-grid">
          <% themeOptions.forEach((theme) => { %>
            <label class="theme-option-card theme-option-card--<%= theme.value %>">
              <input type="radio" name="themeName" value="<%= theme.value %>" <%= settings.themeName === theme.value ? 'checked' : '' %> />
              <div class="theme-option-card__swatches">
                <span></span><span></span><span></span>
              </div>
              <strong><%= theme.label %></strong>
              <small><%= theme.description %></small>
            </label>
          <% }) %>
        </div>

        <button class="button" type="submit">Apply Theme</button>
      </form>
        </article>
      </div>
    </details>

    <details class="dashboard-disclosure">
      <summary class="dashboard-disclosure__summary">
        <div>
          <strong>Fresh start reset</strong>
          <span>Clear test election data and return the portal to a clean setup state.</span>
        </div>
      </summary>

      <div class="dashboard-disclosure__content">
        <article class="dashboard-subpanel stack-md" id="fresh-reset-panel">
          <div class="section-heading section-heading--tight">
            <div>
              <span class="eyebrow">Fresh Election Reset</span>
              <h2>Wipe test data before the real election</h2>
            </div>
            <p>This creates a safety backup first, then clears current voters, positions, candidates, nominations, ballots, archives, and audit history.</p>
          </div>

          <div class="note-block">
            <strong>What stays:</strong> organization logo, declaration settings, theme, admin login, and admin two-factor authentication.
          </div>

          <% if (electionState.isOpen) { %>
            <div class="note-block otp-note--warning">
              <strong>Unavailable right now:</strong> close voting first before you run a full fresh reset.
            </div>
          <% } else { %>
            <form
              class="stack-md"
              action="/admin/system/fresh-reset"
              method="post"
              onsubmit="return confirm('This will create a safety backup and then wipe the current election workspace, archives, and audit history. Continue?');"
            >
              <label class="field">
                <span>Type RESET ENTIRE SYSTEM to continue</span>
                <input
                  name="confirmationText"
                  placeholder="RESET ENTIRE SYSTEM"
                  autocomplete="off"
                  required
                />
              </label>

              <button class="button button-danger" type="submit">Reset Entire System Fresh</button>
            </form>
          <% } %>
        </article>
      </div>
    </details>

    <details class="dashboard-disclosure">
      <summary class="dashboard-disclosure__summary">
        <div>
          <strong>Archive library</strong>
          <span>Review completed elections and open full archive records.</span>
        </div>
      </summary>

      <div class="dashboard-disclosure__content">
        <article class="dashboard-subpanel stack-md">
          <div class="section-heading section-heading--tight">
            <div>
              <span class="eyebrow">Election History</span>
              <h2>Archived elections</h2>
            </div>
            <a class="button button-ghost button-small" href="/admin/archives">View All Archives</a>
          </div>

          <% if (archives.length === 0) { %>
            <div class="empty-state">No archived elections yet. Close and archive a completed election to save it here.</div>
          <% } else { %>
            <div class="archive-grid">
              <% archives.forEach((archive) => { %>
                <article class="archive-card">
                  <div class="archive-card__topline">
                    <strong><%= archive.electionName %></strong>
                    <span><%= formatDateTime(archive.archivedAt) %></span>
                  </div>
                  <div class="mini-metrics-grid">
                    <div><strong><%= archive.totalVoters %></strong><span>Voters</span></div>
                    <div><strong><%= archive.votesCast %></strong><span>Votes</span></div>
                    <div><strong><%= formatPercent(archive.turnoutRate || 0) %></strong><span>Turnout</span></div>
                  </div>
                  <a class="button button-ghost button-small" href="/admin/archives/<%= archive.id %>">Open Archive</a>
                </article>
              <% }) %>
            </div>
          <% } %>
        </article>
      </div>
    </details>
  </div>
</section>

<section class="panel panel-light stack-md dashboard-readiness-card">
  <div class="section-heading section-heading--tight">
    <div>
      <span class="eyebrow">Ballot Readiness</span>
      <h2>Positions still needing attention</h2>
    </div>
    <span class="inline-badge"><%= readinessPercent %> ready</span>
  </div>

  <% if (positionReadiness.length === 0) { %>
    <div class="empty-state">No positions have been added yet.</div>
  <% } else if (positionsNeedingCandidates.length === 0) { %>
    <div class="note-block">
      <strong>Ready:</strong> Every active position already has at least one candidate.
    </div>
  <% } else { %>
    <div class="readiness-grid dashboard-readiness-grid">
      <% positionsNeedingCandidates.forEach((position) => { %>
        <article class="mini-card">
          <strong><%= position.positionName %></strong>
          <span>No candidate added yet</span>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<script>
  (() => {
    const openHashDisclosure = () => {
      if (!window.location.hash) {
        return;
      }

      const target = document.querySelector(window.location.hash);
      const disclosure = target ? target.closest("details") : null;

      if (disclosure) {
        disclosure.open = true;
      }
    };

    openHashDisclosure();
    window.addEventListener("hashchange", openHashDisclosure);
  })();
</script>

<%- include("partials/admin-shell-end") %>
