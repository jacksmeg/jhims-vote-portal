<%- include("partials/public-shell-start", { pageTitle }) %>

<section class="split-stage">
  <div class="panel panel-dark stack-lg">
    <span class="eyebrow">Election Committee</span>
    <h2>Administrator access for election setup and results.</h2>
    <p>
      Sign in here to import voters, register positions and candidates, control the voting
      window, create backups, review audit activity, and unlock final results.
    </p>
    <% if (adminTwoFactorEnabled) { %>
      <p class="note-block">After your password is accepted, you will also enter a 6-digit authenticator code.</p>
    <% } %>
  </div>

  <div class="panel panel-light">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Admin Login</span>
        <h3>Enter committee credentials</h3>
      </div>
    </div>

    <form class="stack-md" action="/admin/login" method="post">
      <label class="field">
        <span>Username</span>
        <input name="username" required />
      </label>

      <label class="field">
        <span>Password</span>
        <input name="password" type="password" required />
      </label>

      <button class="button" type="submit">Open Dashboard</button>
    </form>
  </div>
</section>

<%- include("partials/public-shell-end") %>
