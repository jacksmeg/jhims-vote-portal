<%
  const voterSummary = {
    total: metrics.totalVoters || voters.length,
    verified: voters.filter((voterRow) => Boolean(voterRow.phoneNumber)).length,
    voted: metrics.votedCount || voters.filter((voterRow) => Boolean(voterRow.hasVoted)).length,
  };
  voterSummary.turnoutRate = voterSummary.total
    ? voterSummary.voted / voterSummary.total
    : 0;

  const departmentOptions = Array.from(
    new Set(
      voters
        .map((voterRow) => String(voterRow.department || "").trim())
        .filter(Boolean),
    ),
  ).sort((left, right) => left.localeCompare(right));

  const directoryRows = voters.map((voterRow) => {
    let status = {
      label: "Verified",
      className: "is-verified",
      filterValue: "verified",
    };

    if (voterRow.hasVoted) {
      status = {
        label: "Voted",
        className: "is-voted",
        filterValue: "voted",
      };
    } else if (electionState.isClosed) {
      status = {
        label: "Not Voted",
        className: "is-not-voted",
        filterValue: "not-voted",
      };
    }

    const searchText = [
      voterRow.staffId,
      voterRow.phoneNumber,
      voterRow.fullName,
      voterRow.department,
      status.label,
    ]
      .filter(Boolean)
      .join(" ")
      .toLowerCase();

    return {
      ...voterRow,
      status,
      initials: getInitials(voterRow.fullName || voterRow.staffId),
      searchText,
    };
  });
%>

<%- include("partials/admin-shell-start", {
  pageTitle,
  pageHeading: "Voter Management",
  pageIntro: "Home  ›  Voters  ›  Voter Management",
  currentSection: "voters",
  pageBodyClass: "voter-management-body",
  pageMainClass: "admin-main--voter-management",
  pageTopbarClass: "admin-topbar--voter-management"
}) %>

<section class="voter-management-page stack-lg">
  <section class="voter-summary-grid" aria-label="Voter summary">
    <article class="voter-summary-card is-red">
      <div class="voter-summary-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M16 11a4 4 0 1 0-3.999-4A4 4 0 0 0 16 11Zm-8 2a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm0 2c-2.33 0-7 1.17-7 3.5V20h9v-1.5c0-.97.4-1.86 1.12-2.59A11.66 11.66 0 0 0 8 15Zm8 0c-2.67 0-8 1.34-8 4v1h16v-1c0-2.66-5.33-4-8-4Z" fill="currentColor" />
        </svg>
      </div>
      <div class="voter-summary-card__copy">
        <span>Total Voters</span>
        <strong><%= voterSummary.total.toLocaleString() %></strong>
        <p>Eligible voters</p>
      </div>
      <small>↑ 12.4% from last update</small>
    </article>

    <article class="voter-summary-card is-pink">
      <div class="voter-summary-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M18 3a2 2 0 0 1 2 2v14l-8-4-8 4V5a2 2 0 0 1 2-2h12Zm-2.59 5L12 11.41 10.59 10 9.17 11.41 12 14.24 16.83 9.4 15.41 8ZM12 5.75a1.75 1.75 0 1 0 0 3.5 1.75 1.75 0 0 0 0-3.5Z" fill="currentColor" />
        </svg>
      </div>
      <div class="voter-summary-card__copy">
        <span>Verified Voters</span>
        <strong><%= voterSummary.verified.toLocaleString() %></strong>
        <p>Verified voter records</p>
      </div>
      <small>↑ 15.7% from last update</small>
    </article>

    <article class="voter-summary-card is-yellow">
      <div class="voter-summary-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M13 3v10h8A8 8 0 0 0 13 3Zm-2 2.08A9 9 0 1 0 19.92 15H11V5.08Z" fill="currentColor" />
        </svg>
      </div>
      <div class="voter-summary-card__copy">
        <span>Voted</span>
        <strong><%= voterSummary.voted.toLocaleString() %></strong>
        <p>Total votes cast</p>
      </div>
      <small>↑ 8.2% from last update</small>
    </article>

    <article class="voter-summary-card is-blue">
      <div class="voter-summary-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="m5 16 4.5-4.5 3 3L19 8v3h2V5h-6v2h2.59l-5.09 5.09-3-3L3 15l2 1Z" fill="currentColor" />
        </svg>
      </div>
      <div class="voter-summary-card__copy">
        <span>Turnout</span>
        <strong><%= formatPercent(voterSummary.turnoutRate) %></strong>
        <p>Voter turnout</p>
      </div>
      <small>↑ 8.2% from last update</small>
    </article>
  </section>

  <section class="voter-management-layout">
    <article class="voter-directory-card panel panel-light">
      <div class="voter-directory-card__header">
        <div>
          <div class="voter-directory-card__eyebrow">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M16 11a4 4 0 1 0-3.999-4A4 4 0 0 0 16 11Zm-8 2a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm0 2c-2.33 0-7 1.17-7 3.5V20h9v-1.5c0-.97.4-1.86 1.12-2.59A11.66 11.66 0 0 0 8 15Zm8 0c-2.67 0-8 1.34-8 4v1h16v-1c0-2.66-5.33-4-8-4Z" fill="currentColor" />
            </svg>
            <span>Registered Voters Directory</span>
          </div>
        </div>

        <a class="voter-tool-button" href="/admin/voters">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M12 6V3L8 7l4 4V8a4 4 0 1 1-4 4H6a6 6 0 1 0 6-6Zm6 4a6 6 0 0 1-10.24 4.24l1.42-1.42A4 4 0 1 0 12 8V5l4 4-4 4v-3a4 4 0 0 0-2.82 1.18l-1.42-1.42A6 6 0 0 1 18 10Z" fill="currentColor" />
          </svg>
          Refresh
        </a>
      </div>

      <div class="voter-directory-toolbar">
        <label class="voter-search-field">
          <span class="sr-only">Search voters</span>
          <input
            id="voter-directory-search"
            type="search"
            placeholder="Search by name, staff ID or phone..."
          />
          <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
            <path d="M10 4a6 6 0 1 0 3.874 10.582l4.772 4.772 1.414-1.414-4.772-4.772A6 6 0 0 0 10 4Zm0 2a4 4 0 1 1 0 8 4 4 0 0 1 0-8Z" fill="currentColor" />
          </svg>
        </label>

        <label class="voter-select-field">
          <span class="sr-only">Filter by department</span>
          <select id="voter-directory-department">
            <option value="all">All Departments</option>
            <% departmentOptions.forEach((department) => { %>
              <option value="<%= department.toLowerCase() %>"><%= department %></option>
            <% }) %>
          </select>
        </label>

        <label class="voter-select-field">
          <span class="sr-only">Filter by status</span>
          <select id="voter-directory-status">
            <option value="all">All Status</option>
            <option value="verified">Verified</option>
            <option value="voted">Voted</option>
            <option value="not-voted">Not Voted</option>
            <option value="pending">Pending</option>
          </select>
        </label>

        <button class="voter-tool-button voter-tool-button--icon" id="voter-directory-reset" type="button" aria-label="Reset filters">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M4 4h16l-6 7v5l-4 4v-9L4 4Z" fill="currentColor" />
          </svg>
        </button>
      </div>

      <div class="voter-filter-pills" role="tablist" aria-label="Quick voter filters">
        <button class="voter-filter-pill is-active" data-voter-filter="all" type="button">
          All
        </button>
        <button class="voter-filter-pill" data-voter-filter="verified" type="button">
          Verified
        </button>
        <button class="voter-filter-pill" data-voter-filter="voted" type="button">
          Voted
        </button>
        <button class="voter-filter-pill" data-voter-filter="not-voted" type="button">
          Not Voted
        </button>
        <button class="voter-filter-pill" data-voter-filter="pending" type="button">
          Pending
        </button>
      </div>

      <% if (directoryRows.length === 0) { %>
        <div class="voter-directory-empty-state">
          No voters have been added yet. Upload Excel records or add a single voter manually.
        </div>
      <% } else { %>
        <div class="voter-directory-table-wrap">
          <table class="voter-directory-table">
            <thead>
              <tr>
                <th>Staff ID</th>
                <th>Name</th>
                <th>Phone Number</th>
                <th>Department</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="voter-directory-body">
              <% directoryRows.forEach((voterRow) => { %>
                <tr
                  data-voter-row
                  data-search="<%= voterRow.searchText %>"
                  data-status="<%= voterRow.status.filterValue %>"
                  data-department="<%= String(voterRow.department || '').trim().toLowerCase() || 'unassigned' %>"
                >
                  <td>
                    <strong><%= voterRow.staffId %></strong>
                  </td>
                  <td>
                    <div class="voter-directory-person">
                      <span class="voter-directory-person__avatar"><%= voterRow.initials %></span>
                      <div>
                        <strong><%= voterRow.fullName || 'Unnamed Voter' %></strong>
                        <small><%= voterRow.fullName ? 'Registered voter record' : 'Name not provided' %></small>
                      </div>
                    </div>
                  </td>
                  <td><%= voterRow.phoneNumber %></td>
                  <td><%= voterRow.department || '—' %></td>
                  <td>
                    <span class="voter-status-pill <%= voterRow.status.className %>">
                      <%= voterRow.status.label %>
                    </span>
                  </td>
                  <td>
                    <div class="voter-row-actions">
                      <a
                        class="voter-row-actions__button"
                        href="/admin/voters/<%= voterRow.id %>/edit"
                        aria-label="View voter <%= voterRow.staffId %>"
                        title="View voter"
                      >
                        <svg viewBox="0 0 24 24" focusable="false">
                          <path d="M12 5c5.5 0 9.5 4.3 10.7 6-.16.23-.38.54-.65.9C20.79 13.5 17.16 17 12 17S3.21 13.5 1.95 11.9A14.17 14.17 0 0 1 1.3 11C2.5 9.3 6.5 5 12 5Zm0 2C8.53 7 5.73 9.3 4.12 11 5.73 12.7 8.53 15 12 15s6.27-2.3 7.88-4C18.27 9.3 15.47 7 12 7Zm0 1.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5Z" fill="currentColor" />
                        </svg>
                      </a>

                      <a
                        class="voter-row-actions__button"
                        href="/admin/voters/<%= voterRow.id %>/edit"
                        aria-label="Edit voter <%= voterRow.staffId %>"
                        title="Edit voter"
                      >
                        <svg viewBox="0 0 24 24" focusable="false">
                          <path d="m4 17.25 9.2-9.2 2.75 2.75-9.2 9.2H4v-2.75Zm10.6-10.6 1.44-1.44a1.5 1.5 0 0 1 2.12 0l.63.63a1.5 1.5 0 0 1 0 2.12l-1.44 1.44-2.75-2.75Z" fill="currentColor" />
                        </svg>
                      </a>

                      <form
                        action="/admin/voters/<%= voterRow.id %>/delete"
                        method="post"
                        onsubmit="return confirm('Remove voter <%= voterRow.staffId %> from the list?');"
                      >
                        <button
                          class="voter-row-actions__button is-danger"
                          type="submit"
                          aria-label="Delete voter <%= voterRow.staffId %>"
                          title="Delete voter"
                          <%= electionState.canEditSetup ? '' : 'disabled' %>
                        >
                          <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M9 3h6l1 2h4v2H4V5h4l1-2Zm1 6h2v8h-2V9Zm4 0h2v8h-2V9ZM7 9h2v8H7V9Zm-1 11a2 2 0 0 1-2-2V8h16v10a2 2 0 0 1-2 2H6Z" fill="currentColor" />
                          </svg>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>

          <div class="voter-directory-empty-state" id="voter-directory-empty" hidden>
            No voters match the current search or filter.
          </div>
        </div>

        <div class="voter-directory-footer">
          <p id="voter-directory-summary">Showing 1 to 10 of <%= directoryRows.length.toLocaleString() %> entries</p>
          <nav class="voter-pagination" id="voter-directory-pagination" aria-label="Voter pagination"></nav>
        </div>
      <% } %>
    </article>

    <aside class="voter-management-side">
      <article class="voter-side-card is-red-outline">
        <div class="voter-side-card__header">
          <span class="voter-side-card__icon is-red" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 3 4 8v2h16V8l-8-5Zm0 8-6 4v2h12v-2l-6-4Zm0 2.4 2.5 1.67V19h-5v-3.93L12 13.4Z" fill="currentColor" />
            </svg>
          </span>
          <div>
            <h3>Import Voters from Excel</h3>
            <p>Import multiple voters at once using an Excel file.</p>
          </div>
        </div>

        <form
          class="voter-side-card__content stack-md"
          id="voter-import-form"
          action="/admin/voters/import"
          method="post"
          enctype="multipart/form-data"
        >
          <input
            class="sr-only"
            id="voter-import-file"
            name="voterFile"
            type="file"
            accept=".xlsx,.xls,.csv"
            <%= electionState.canEditSetup ? '' : 'disabled' %>
          />

          <div class="voter-side-card__button-row">
            <a class="voter-action-button is-yellow" href="<%= templatePath %>">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M11 3h2v9.59l2.3-2.29 1.4 1.4L12 16.4l-4.7-4.7 1.4-1.4 2.3 2.29V3ZM5 19h14v2H5v-2Z" fill="currentColor" />
              </svg>
              Download Template
            </a>

            <button
              class="voter-action-button is-red"
              id="voter-import-trigger"
              type="button"
              <%= electionState.canEditSetup ? '' : 'disabled' %>
            >
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M11 4h2v7.59l2.3-2.29 1.4 1.4L12 15.4l-4.7-4.7 1.4-1.4 2.3 2.29V4Zm-6 9h2v5h10v-5h2v7H5v-7Z" fill="currentColor" />
              </svg>
              Upload Excel
            </button>
          </div>

          <p class="voter-side-card__support-copy" id="voter-import-filename">Supported format: .xlsx, .xls, .csv</p>

          <button
            class="voter-outline-action"
            type="submit"
            formaction="/admin/voters/clear"
            formmethod="post"
            onclick="return confirm('This will remove all imported voters from the current setup. Continue?');"
            <%= electionState.canEditSetup && voterSummary.total > 0 ? '' : 'disabled' %>
          >
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M9 3h6l1 2h4v2H4V5h4l1-2Zm1 6h2v8h-2V9Zm4 0h2v8h-2V9ZM7 9h2v8H7V9Zm-1 11a2 2 0 0 1-2-2V8h16v10a2 2 0 0 1-2 2H6Z" fill="currentColor" />
            </svg>
            Clear Imported List
          </button>

          <% if (!electionState.canEditSetup) { %>
            <p class="voter-side-card__lock-note">Voter import is locked after voting opens.</p>
          <% } %>
        </form>
      </article>

      <article class="voter-side-card is-pink-outline">
        <div class="voter-side-card__header">
          <span class="voter-side-card__icon is-pink" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M16 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4ZM8 13a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm0 2c-2.33 0-7 1.17-7 3.5V20h9v-1.5c0-.97.4-1.86 1.12-2.59A11.66 11.66 0 0 0 8 15Zm8 0c-2.67 0-8 1.34-8 4v1h8v-3h3v-2h-3v-3h-2v3h-3v2h3v3h8v-1c0-2.66-5.33-4-8-4Z" fill="currentColor" />
            </svg>
          </span>
          <div>
            <h3>Add Single Voter</h3>
            <p>Register a new voter manually.</p>
          </div>
        </div>

        <form class="voter-side-card__content stack-md" action="/admin/voters" method="post">
          <div class="voter-side-card__field-grid">
            <label class="field">
              <span>Staff ID</span>
              <input
                name="staffId"
                placeholder="e.g. STF0234"
                <%= electionState.canEditSetup ? '' : 'disabled' %>
                required
              />
            </label>

            <label class="field">
              <span>Phone Number</span>
              <input
                name="phoneNumber"
                placeholder="e.g. 024 123 4567"
                <%= electionState.canEditSetup ? '' : 'disabled' %>
                required
              />
            </label>
          </div>

          <div class="voter-side-card__field-grid">
            <label class="field">
              <span>Full Name</span>
              <input
                name="fullName"
                placeholder="Staff full name"
                <%= electionState.canEditSetup ? '' : 'disabled' %>
              />
            </label>

            <label class="field">
              <span>Department</span>
              <input
                name="department"
                placeholder="Department"
                <%= electionState.canEditSetup ? '' : 'disabled' %>
              />
            </label>
          </div>

          <button class="voter-action-button is-pink" type="submit" <%= electionState.canEditSetup ? '' : 'disabled' %>>
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M17 3H5a2 2 0 0 0-2 2v14l4-3h10a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2Zm-1 9H6v-2h10v2Zm0-4H6V6h10v2Z" fill="currentColor" />
            </svg>
            Save Voter
          </button>
        </form>
      </article>

      <article class="voter-side-card is-yellow-outline">
        <div class="voter-side-card__header">
          <span class="voter-side-card__icon is-yellow" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M7 11h10v2H7v-2Zm5-9 8 4v6c0 5.18-3.42 9.99-8 11.28C7.42 21.99 4 17.18 4 12V6l8-4Z" fill="currentColor" />
            </svg>
          </span>
          <div>
            <h3>Bulk Actions</h3>
            <p>Perform actions on the voter directory.</p>
          </div>
        </div>

        <div class="voter-side-card__content stack-md">
          <div class="voter-side-card__button-row">
            <a class="voter-action-button is-red" href="/admin/voters/export/pdf">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M6 2h9l5 5v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Zm8 1.5V8h4.5L14 3.5ZM8 13h2.8a1.6 1.6 0 0 1 0 3.2H10V19H8v-6Zm2 1.4V14.8h.64a.4.4 0 1 0 0-.8H10Zm4-1.4h2.2A1.8 1.8 0 0 1 18 14.8v2.4a1.8 1.8 0 0 1-1.8 1.8H14v-6Zm2 1.4v3.2h.18a.4.4 0 0 0 .4-.4v-2.4a.4.4 0 0 0-.4-.4H16Zm3-1.4h4v1.4h-2.6v1h2.2v1.4h-2.2V19H19v-6Z" fill="currentColor" transform="translate(-1.5 0)" />
              </svg>
              Export PDF
            </a>

            <a class="voter-action-button is-yellow-outline" href="/admin/voters/export/excel">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M6 3h9l5 5v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm8 1.5V8h3.5L14 4.5ZM8.5 11 10 13.2 11.5 11H13l-2.2 3L13 17h-1.5L10 14.8 8.5 17H7l2.2-3L7 11h1.5Z" fill="currentColor" />
              </svg>
              Export Excel
            </a>

            <details class="voter-more-actions">
              <summary>More Actions</summary>
              <a href="/admin/audit">Open Audit Log</a>
              <a href="/admin/results">View Results</a>
              <a href="/admin">Go to Dashboard</a>
            </details>
          </div>
        </div>
      </article>

      <article class="voter-side-card is-blue-outline">
        <div class="voter-side-card__header">
          <span class="voter-side-card__icon is-blue" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M7 4h10a4 4 0 0 1 4 4v7a4 4 0 0 1-4 4h-1v3l-4-3H7a4 4 0 0 1-4-4V8a4 4 0 0 1 4-4Zm0 2a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h5.67L14 18.25V17h3a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2H7Z" fill="currentColor" />
            </svg>
          </span>
          <div>
            <h3>Print Options</h3>
            <p>Print voter list and ballot paper.</p>
          </div>
        </div>

        <div class="voter-side-card__content stack-md">
          <a class="voter-action-button is-blue" href="/admin/ballot-layout">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M7 3h10v4H7V3Zm10 6h1a3 3 0 0 1 3 3v5h-4v4H7v-4H3v-5a3 3 0 0 1 3-3h1v2h10V9Zm-2 10v-4H9v4h6Zm3-4h1v-3a1 1 0 0 0-1-1h-1v4h1Z" fill="currentColor" />
            </svg>
            Print Ballot Paper
          </a>
        </div>
      </article>
    </aside>
  </section>

  <section class="voter-activity-card panel panel-light" id="recent-voter-activity">
    <div class="voter-activity-card__header">
      <div>
        <div class="voter-directory-card__eyebrow is-blue">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M12 1.75a10.25 10.25 0 1 0 10.25 10.25A10.26 10.26 0 0 0 12 1.75Zm0 2a8.25 8.25 0 1 1-8.25 8.25A8.26 8.26 0 0 1 12 3.75ZM11 7h2v5.59l3.3 3.3-1.42 1.41L11 13.41V7Z" fill="currentColor" />
          </svg>
          <span>Recent Voter Activity</span>
        </div>
      </div>

      <a class="voter-tool-button" href="/admin/audit">View All Activity</a>
    </div>

    <% if (!voterActivity || voterActivity.length === 0) { %>
      <div class="voter-directory-empty-state">
        No recent voter activity has been recorded yet.
      </div>
    <% } else { %>
      <div class="voter-activity-table-wrap">
        <table class="voter-activity-table">
          <thead>
            <tr>
              <th>Activity</th>
              <th>Staff ID</th>
              <th>Details</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            <% voterActivity.forEach((activity) => { %>
              <tr>
                <td><strong><%= activity.actionLabel %></strong></td>
                <td><%= activity.staffReference || '—' %></td>
                <td><%= activity.detailLabel || 'Recent voter activity recorded by the system.' %></td>
                <td><%= activity.timeAgo %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</section>

<script>
  (() => {
    const searchInput = document.getElementById("voter-directory-search");
    const departmentSelect = document.getElementById("voter-directory-department");
    const statusSelect = document.getElementById("voter-directory-status");
    const resetButton = document.getElementById("voter-directory-reset");
    const filterButtons = Array.from(document.querySelectorAll("[data-voter-filter]"));
    const rows = Array.from(document.querySelectorAll("[data-voter-row]"));
    const summary = document.getElementById("voter-directory-summary");
    const pagination = document.getElementById("voter-directory-pagination");
    const emptyState = document.getElementById("voter-directory-empty");
    const pageSize = 10;
    let activeQuickFilter = "all";
    let currentPage = 1;

    const updateDirectory = () => {
      if (!rows.length) {
        return;
      }

      const searchValue = String(searchInput?.value || "").trim().toLowerCase();
      const departmentValue = String(departmentSelect?.value || "all").trim().toLowerCase();
      const statusValue = String(statusSelect?.value || "all").trim().toLowerCase();

      const filteredRows = rows.filter((row) => {
        const rowSearch = row.dataset.search || "";
        const rowDepartment = row.dataset.department || "";
        const rowStatus = row.dataset.status || "";

        const matchesSearch = !searchValue || rowSearch.includes(searchValue);
        const matchesDepartment = departmentValue === "all" || rowDepartment === departmentValue;
        const effectiveStatusFilter = activeQuickFilter === "all" ? statusValue : activeQuickFilter;
        const matchesStatus = effectiveStatusFilter === "all" || rowStatus === effectiveStatusFilter;

        return matchesSearch && matchesDepartment && matchesStatus;
      });

      const totalPages = Math.max(Math.ceil(filteredRows.length / pageSize), 1);
      currentPage = Math.min(currentPage, totalPages);
      const startIndex = (currentPage - 1) * pageSize;
      const visibleRows = filteredRows.slice(startIndex, startIndex + pageSize);

      rows.forEach((row) => {
        row.hidden = !visibleRows.includes(row);
      });

      if (summary) {
        if (!filteredRows.length) {
          summary.textContent = "Showing 0 to 0 of 0 entries";
        } else {
          const from = startIndex + 1;
          const to = Math.min(startIndex + visibleRows.length, filteredRows.length);
          summary.textContent = `Showing ${from} to ${to} of ${filteredRows.length.toLocaleString()} entries`;
        }
      }

      if (emptyState) {
        emptyState.hidden = filteredRows.length > 0;
      }

      if (pagination) {
        pagination.innerHTML = "";

        if (filteredRows.length > pageSize) {
          for (let page = 1; page <= totalPages; page += 1) {
            const button = document.createElement("button");
            button.type = "button";
            button.className = `voter-pagination__button${page === currentPage ? " is-active" : ""}`;
            button.textContent = String(page);
            button.addEventListener("click", () => {
              currentPage = page;
              updateDirectory();
            });
            pagination.appendChild(button);
          }
        }
      }
    };

    searchInput?.addEventListener("input", () => {
      currentPage = 1;
      updateDirectory();
    });

    departmentSelect?.addEventListener("change", () => {
      currentPage = 1;
      updateDirectory();
    });

    statusSelect?.addEventListener("change", () => {
      activeQuickFilter = "all";
      filterButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.voterFilter === "all");
      });
      currentPage = 1;
      updateDirectory();
    });

    resetButton?.addEventListener("click", () => {
      if (searchInput) {
        searchInput.value = "";
      }

      if (departmentSelect) {
        departmentSelect.value = "all";
      }

      if (statusSelect) {
        statusSelect.value = "all";
      }

      activeQuickFilter = "all";
      currentPage = 1;
      filterButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.voterFilter === "all");
      });
      updateDirectory();
    });

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeQuickFilter = button.dataset.voterFilter || "all";
        currentPage = 1;
        filterButtons.forEach((chip) => {
          chip.classList.toggle("is-active", chip === button);
        });
        updateDirectory();
      });
    });

    const importTrigger = document.getElementById("voter-import-trigger");
    const importFileInput = document.getElementById("voter-import-file");
    const importForm = document.getElementById("voter-import-form");
    const importFilename = document.getElementById("voter-import-filename");

    importTrigger?.addEventListener("click", () => {
      importFileInput?.click();
    });

    importFileInput?.addEventListener("change", () => {
      const selectedFile = importFileInput.files && importFileInput.files[0];

      if (importFilename) {
        importFilename.textContent = selectedFile
          ? `Selected file: ${selectedFile.name}`
          : "Supported format: .xlsx, .xls, .csv";
      }

      if (selectedFile) {
        importForm?.submit();
      }
    });

    updateDirectory();
  })();
</script>

<%- include("partials/admin-shell-end") %>
