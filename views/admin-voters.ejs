<%- include("partials/admin-shell-start", {
  pageTitle,
  pageHeading: "Voter Registration",
  pageIntro: "Import registered staff members from Excel and review who has already voted.",
  currentSection: "voters"
}) %>

<section class="admin-grid">
  <article class="panel panel-light stack-md">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Excel Import</span>
        <h2>Upload voter login records</h2>
      </div>
      <p>Required columns: staff_id and phone_number. Optional: full_name and department.</p>
    </div>

    <div class="button-row">
      <a class="button button-ghost" href="<%= templatePath %>">Download Staff Login Template</a>
    </div>

    <form class="stack-md" action="/admin/voters/import" method="post" enctype="multipart/form-data">
      <label class="field">
        <span>Excel or CSV file</span>
        <input name="voterFile" type="file" accept=".xlsx,.xls,.csv" required />
      </label>

      <button class="button" type="submit" <%= electionState.canEditSetup ? '' : 'disabled' %>>
        Upload Voters
      </button>
    </form>
  </article>

  <article class="panel panel-light stack-md">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Manual Entry</span>
        <h2>Add a voter directly</h2>
      </div>
      <p>Use this form when you want to register one staff member without uploading Excel.</p>
    </div>

    <form class="stack-md" action="/admin/voters" method="post">
      <div class="form-grid">
        <label class="field">
          <span>Staff ID</span>
          <input name="staffId" placeholder="STF0234" <%= electionState.canEditSetup ? '' : 'disabled' %> required />
        </label>

        <label class="field">
          <span>Phone Number</span>
          <input name="phoneNumber" placeholder="0240000000" <%= electionState.canEditSetup ? '' : 'disabled' %> required />
        </label>
      </div>

      <div class="form-grid">
        <label class="field">
          <span>Full Name</span>
          <input name="fullName" placeholder="Staff Member Name" <%= electionState.canEditSetup ? '' : 'disabled' %> />
        </label>

        <label class="field">
          <span>Department</span>
          <input name="department" placeholder="Department" <%= electionState.canEditSetup ? '' : 'disabled' %> />
        </label>
      </div>

      <button class="button" type="submit" <%= electionState.canEditSetup ? '' : 'disabled' %>>
        Save Voter
      </button>
    </form>
  </article>

  <article class="panel panel-light stack-md">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Summary</span>
        <h2>Current voter counts</h2>
      </div>
    </div>

    <div class="stack-sm">
      <div class="info-row"><span>Total voters</span><strong><%= metrics.totalVoters %></strong></div>
      <div class="info-row"><span>Already voted</span><strong><%= metrics.votedCount %></strong></div>
      <div class="info-row">
        <span>Turnout</span>
        <strong><%= metrics.totalVoters ? formatPercent(metrics.votedCount / metrics.totalVoters) : '0.0%' %></strong>
      </div>
    </div>

    <form
      class="stack-sm"
      action="/admin/voters/clear"
      method="post"
      onsubmit="return confirm('This will remove all imported voters from the current setup. Continue?');"
    >
      <button
        class="button button-danger"
        type="submit"
        <%= electionState.canEditSetup && metrics.totalVoters > 0 ? '' : 'disabled' %>
      >
        Clear Imported Voters
      </button>

      <% if (!electionState.canEditSetup) { %>
        <p class="note-block">Voter deletion is locked once voting has been opened.</p>
      <% } else if (metrics.totalVoters === 0) { %>
        <p class="note-block">Import voters first before using the clear action.</p>
      <% } %>
    </form>
  </article>
</section>

<section class="panel panel-light stack-md">
  <div class="section-heading">
    <div>
      <span class="eyebrow">Registered Staff</span>
      <h2>Imported voter list</h2>
    </div>
    <p>Staff IDs are unique and each record can be marked as voted once.</p>
  </div>

  <% if (voters.length === 0) { %>
    <div class="empty-state">No voters have been imported yet.</div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Staff ID</th>
            <th>Phone Number</th>
            <th>Name</th>
            <th>Department</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% voters.forEach((voterRow) => { %>
            <%
              const voterStatus = voterRow.hasVoted
                ? { label: 'Voted', className: 'inline-badge--success' }
                : electionState.isClosed
                  ? { label: 'Did Not Vote', className: 'inline-badge--warning' }
                  : electionState.isOpen
                    ? { label: 'Ready to Vote', className: 'inline-badge--info' }
                    : { label: 'Registered', className: 'inline-badge--muted' };
            %>
            <tr>
              <td><strong><%= voterRow.staffId %></strong></td>
              <td><%= voterRow.phoneNumber %></td>
              <td><%= voterRow.fullName || '—' %></td>
              <td><%= voterRow.department || '—' %></td>
              <td>
                <span class="inline-badge <%= voterStatus.className %>">
                  <%= voterStatus.label %>
                </span>
              </td>
              <td>
                <% if (electionState.canEditSetup) { %>
                  <a class="button button-ghost button-small" href="/admin/voters/<%= voterRow.id %>/edit">
                    Edit
                  </a>
                <% } else { %>
                  <span class="inline-badge inline-badge--muted">Locked</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include("partials/admin-shell-end") %>
